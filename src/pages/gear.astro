            {cat: "PLUGIN", name: "Waves Gold", desc: "WAVESのエントリーバンドル。EQ、コンプ、リバーブなど基本的なミックスツールを収録。", specs: "Mixing Tools", color: "var(--pop-4)", img: "/img/wavesgoldbundle_2.jpg"},
            {cat: "PLUGIN", name: "Soundtoys", desc: "クリエイティブなエフェクト集。ディレイ、ディストーション、モジュレーションなど、音作りに特化。", specs: "Creative FX", color: "var(--pop-4)", img: ""},
            {cat: "PLUGIN", name: "Plugin Alliance", desc: "複数ブランドのプラグインを提供。Brainworx、SPL、bx_digitalなど高品質なツールを収録。", specs: "Mixing/Mastering", color: "var(--pop-4)", img: ""},
            {cat: "PLUGIN", name: "Sonible", desc: "AI搭載のミックス・マスタリングツール。smart:EQ、smart:compなど自動最適化機能を搭載。", specs: "AI Tools", color: "var(--pop-4)", img: ""},

            // NEW PLUGINS
            {cat: "PLUGIN", name: "BFD3", desc: "アコースティックドラム専用音源。高品質なマルチサンプリングで、リアルなドラムトラックを制作。", specs: "Acoustic Drums", color: "var(--pop-4)", img: "/img/BFD3.jpeg"},
            {cat: "PLUGIN", name: "Synthesizer V Studio 2", desc: "次世代のボーカルシンセサイザー。自然な歌声を生成し、楽曲制作に使用。", specs: "AI Vocal", color: "var(--pop-4)", img: "/img/SV2.png"},
            {cat: "PLUGIN", name: "Melody Sauce 2", desc: "AIがメロディを自動生成。作曲のアイデア出しや、フレーズのバリエーション作成に活用。", specs: "AI Melody", color: "var(--pop-4)", img: "/img/melody-sauce-2-2.png"},
            {cat: "PLUGIN", name: "SubLab XL", desc: "重低音専用シンセサイザー。EDM、ヒップホップなどで迫力あるベースラインを制作。", specs: "Bass Synth", color: "var(--pop-4)", img: "/img/XL.jpeg"},
            {cat: "PLUGIN", name: "KOMPLETE 13", desc: "Native Instrumentsの総合音源パッケージ。シンセ、サンプラー、エフェクトなど100種類以上を収録。", specs: "Ultimate Bundle", color: "var(--pop-4)", img: "/img/KOMPLETE.jpg"},
            {cat: "PLUGIN", name: "Keyscape", desc: "Spectrasonicsのコレクター級キーボード音源。36種類のヴィンテージ鍵盤楽器をサンプリング。", specs: "Spectrasonics", color: "var(--pop-4)", img: "/img/Keyscape.jpg"},
            {cat: "PLUGIN", name: "Omnisphere", desc: "Spectrasonicsのフラッグシップシンセ。膨大なサウンドライブラリで、映画音楽からEDMまで対応。", specs: "Spectrasonics", color: "var(--pop-4)", img: "/img/Omni.jpg"},
            {cat: "PLUGIN", name: "EZbass", desc: "Toontrackのベース音源。リアルな演奏を簡単に打ち込み可能。", specs: "Toontrack", color: "var(--pop-4)", img: "/img/EZbass.png"},
            {cat: "PLUGIN", name: "EZkeys 2", desc: "Toontrackのピアノ・キーボード音源。コード進行やメロディを自動生成する機能を搭載。", specs: "Toontrack", color: "var(--pop-4)", img: "/img/EZkeys2.png"},
            {cat: "PLUGIN", name: "Superior Drummer 3", desc: "Toontrackの最高峰ドラム音源。230GB超のサンプルライブラリで、プロレベルのドラムトラックを制作。", specs: "Toontrack", color: "var(--pop-4)", img: "/img/SuperiorDrummer3.png"},
            {cat: "PLUGIN", name: "XO", desc: "AIがドラムサンプルを視覚的に配置。直感的な操作で理想のドラムサウンドを発見。", specs: "XLN Audio", color: "var(--pop-4)", img: "/img/XO.png"},
            {cat: "PLUGIN", name: "Life", desc: "あらゆる音をドラムキット化。日常の音や楽器をリズムトラックに変換。", specs: "XLN Audio", color: "var(--pop-4)", img: "/img/XLN-Audio-Life.webp"},
            {cat: "PLUGIN", name: "Neural DSP", desc: "Gojiraのギターサウンドを再現。メタル系の重厚なディストーションとエフェクトを搭載。", specs: "Gojira / Archetype", color: "var(--pop-4)", img: "/img/a-gojira-x-standalone.png"}
        ];

        const moreGrid = document.getElementById('more-grid');
        if (!moreGrid) { console.error('❌ ERROR: more-grid要素が見つかりません！'); return; }

        const popColors = [
            "var(--pop-1)", "var(--pop-2)", "var(--pop-3)", "var(--pop-4)", "var(--pop-5)", "var(--pop-6)",
            "#FF00FF", "#00FF99", "#FF3300", "#AA00FF", "#0088FF", "#CCFF33", "#FF66FF", "#00CCFF", "#FFCC00"
        ];
        const getRandomColor = () => popColors[Math.floor(Math.random() * popColors.length)];

        moreData.forEach((item, index) => {
            const el = document.createElement('div');
            el.className = 'more-item';
            // CSS変数として色を渡す
            el.style.setProperty('--color', item.color);
            el.style.borderLeftColor = item.color; 
            
            el.innerHTML = `
                <div class="more-cat-tag" style="border-color:${item.color}; color:${item.color};">${item.cat}</div>
                <div class="more-name">${item.name}</div>
            `;
            
            const globalIndex = mainGearData.length + index;
            el.addEventListener('click', () => openModal(globalIndex));
            
            // ランダムカラーホバー
            el.addEventListener('mouseenter', () => {
                if (cursor) cursor.classList.add('hovered');
                const randomColor = getRandomColor();
                el.style.boxShadow = `0 0 20px ${randomColor}`;
                el.style.borderColor = randomColor;
                el.style.background = randomColor;
                el.querySelector('.more-name').style.color = 'black';
                el.querySelector('.more-cat-tag').style.color = 'black';
                el.querySelector('.more-cat-tag').style.borderColor = 'black';
                el.style.boxShadow = `0 0 30px ${randomColor}, inset 0 0 20px white`;
            });
            el.addEventListener('mouseleave', () => {
                if (cursor) cursor.classList.remove('hovered');
                el.style.boxShadow = 'none';
                el.style.borderColor = '#444';
                el.style.borderLeftColor = item.color; 
                el.style.background = 'rgba(255,255,255,0.05)';
                el.querySelector('.more-name').style.color = 'var(--c-white)';
                el.querySelector('.more-cat-tag').style.color = item.color;
                el.querySelector('.more-cat-tag').style.borderColor = item.color;
            });

            moreGrid.appendChild(el);
        });

        // Modal Logic Updated
        const modalOverlay = document.getElementById('modal-overlay');
        const modalWindow = document.getElementById('modal-window');
        const modalClose = document.getElementById('modal-close');
        const mImg = document.getElementById('modal-img');
        const mTag = document.getElementById('modal-tag');
        const mTitle = document.getElementById('modal-title');
        const mJp = document.getElementById('modal-jp');
        const mDesc = document.getElementById('modal-desc');
        const mSpecs = document.getElementById('modal-specs');
        const btnPrev = document.getElementById('modal-prev');
        const btnNext = document.getElementById('modal-next');
        const modalImgArea = document.querySelector('.modal-img-area');
        const modalInfoArea = document.querySelector('.modal-info-area');
        
        if (!modalOverlay || !modalWindow || !modalClose || !mImg || !mTag || !mTitle || !mJp || !mDesc || !mSpecs || !btnPrev || !btnNext || !modalImgArea || !modalInfoArea) {
            console.error('❌ ERROR: モーダル要素が見つかりません！');
            return;
        }
        
        // All Data
        const allGearData = [...mainGearData, ...moreData.map(item => ({
            name: item.name,
            jp: item.cat, 
            tag: item.cat,
            color: item.color,
            img: item.img,
            desc: item.desc,
            specs: item.specs,
            source: 'more'
        }))];
        let currentModalIndex = 0;

        const updateModalContent = (index) => {
            const data = allGearData[index];
            // 画像パスが空の場合はプレースホルダーを表示
            mImg.src = data.img ? data.img : 'data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22300%22%20height%3D%22200%22%20viewBox%3D%220%200%20300%20200%22%3E%3Crect%20fill%3D%22%23333%22%20width%3D%22300%22%20height%3D%22200%22%2F%3E%3Ctext%20fill%3D%22%23555%22%20font-family%3D%22sans-serif%22%20font-size%3D%2230%22%20dy%3D%2210.5%22%20font-weight%3D%22bold%22%20x%3D%2250%25%22%20y%3D%2250%25%22%20text-anchor%3D%22middle%22%3ENO%20IMAGE%3C%2Ftext%3E%3C%2Fsvg%3E';
            mImg.alt = data.name;
            mTag.textContent = data.tag;
            
            // ランダムカラー
            modalImgArea.style.background = getRandomColor();
            modalInfoArea.style.background = getRandomColor();
            
            mTitle.textContent = data.name;
            mJp.textContent = data.jp;
            mDesc.textContent = data.desc;
            mSpecs.textContent = data.specs;
        };

        const openModal = (index) => {
            currentModalIndex = index;
            updateModalContent(currentModalIndex);

            modalOverlay.style.display = 'flex';
            if (cursor) cursor.classList.add('on-modal');
            
            gsap.fromTo(modalOverlay, {opacity: 0}, {opacity: 1, duration: 0.3});
            gsap.fromTo(modalWindow, {scale: 0.8, y: 50}, {scale: 1, y: 0, duration: 0.5, ease: 'back.out(1.2)'});
        }

        const nextItem = () => {
            currentModalIndex = (currentModalIndex + 1) % allGearData.length;
            updateModalContent(currentModalIndex);
            gsap.fromTo(modalWindow, {x: 5}, {x: 0, duration: 0.1, ease: "elastic.out(1, 0.3)"});
        };

        const prevItem = () => {
            currentModalIndex = (currentModalIndex - 1 + allGearData.length) % allGearData.length;
            updateModalContent(currentModalIndex);
            gsap.fromTo(modalWindow, {x: -5}, {x: 0, duration: 0.1, ease: "elastic.out(1, 0.3)"});
        };

        btnNext.addEventListener('click', (e) => {
            e.stopPropagation();
            nextItem();
        });
        btnPrev.addEventListener('click', (e) => {
            e.stopPropagation();
            prevItem();
        });

        const closeModal = () => {
            gsap.to(modalOverlay, {opacity: 0, duration: 0.3, onComplete: () => {
                modalOverlay.style.display = 'none';
                if (cursor) cursor.classList.remove('on-modal');
            }});
        };

        modalClose.addEventListener('click', closeModal);
        // modal-overlay（ギア詳細用）のクリックイベントはそのまま
        modalOverlay.addEventListener('click', (e) => {
            if(e.target === modalOverlay) closeModal();
        });

        // Main Cards Click Logic
        mainGearCards.forEach((card, index) => {
            const color = card.dataset.color;
            card.addEventListener('mouseenter', () => {
                card.style.borderColor = color;
                card.style.boxShadow = `0 0 40px ${color}`;
            });
            card.addEventListener('mouseleave', () => {
                card.style.borderColor = '#333';
                card.style.boxShadow = '0 10px 30px rgba(0,0,0,0.5)';
            });
            
            card.addEventListener('click', () => openModal(index));
        });
    }
</script>

    .cat-title { font-size: 4rem; font-family: var(--font-en); color: var(--c-text); line-height: 1; }
    .cat-title span { color: var(--pop-2); font-size: 5rem; margin-right: 10px; -webkit-text-stroke: 0px; }
    .cat-desc { font-size: 1rem; max-width: 400px; text-align: right; color: #aaa; }

    .gear-grid { 
        display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 40px; 
        margin-bottom: 120px;
    }

    /* 3D CARD STYLE */
    .gear-card {
        background: #1a1a1a; border-radius: 20px; overflow: hidden;
        transform-style: preserve-3d; transform: perspective(1000px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        transition: box-shadow 0.3s, border-color 0.3s;
        border: 2px solid #333;
        cursor: pointer;
        position: relative; z-index: 1;
    }
    .gear-card:hover { z-index: 10; }
    
    .card-img-box { 
        height: 250px; width: 100%; overflow: hidden; position: relative; 
        background: radial-gradient(circle, #333, #111);
        display: flex; justify-content: center; align-items: center;
    }
    .card-img { 
        width: 85%; height: 85%; object-fit: contain; 
        transition: 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        transform: translateZ(20px); 
        filter: drop-shadow(0 10px 20px rgba(0,0,0,0.5));
    }
    .gear-card:hover .card-img { transform: translateZ(60px) scale(1.1) rotate(-2deg); }

    .card-content { padding: 25px; transform: translateZ(30px); background: #1a1a1a; position: relative; }
    .card-tag { 
        position: absolute; top: -15px; right: 20px; 
        background: var(--c-text); color: var(--c-black); 
        padding: 5px 15px; font-weight: 900; font-family: var(--font-en); 
        border-radius: 4px; transform: translateZ(40px); 
        box-shadow: 0 5px 10px rgba(0,0,0,0.3);
    }
    .card-name { 
        font-size: 1.8rem; font-family: var(--font-en); line-height: 1; margin-bottom: 10px; 
        color: var(--c-text); transition: 0.3s; text-shadow: 0 0 10px rgba(0,0,0,0.5);
    }
    .gear-card:hover .card-name { text-shadow: 0 0 15px currentColor; }
    
    .card-jp { font-size: 0.9rem; color: #aaa; font-weight: bold; margin-bottom: 15px; font-family: var(--font-digi); transition: 0.3s; }
    .gear-card:hover .card-jp { color: var(--c-white); }

    .card-desc { font-size: 0.9rem; line-height: 1.6; color: #888; transition: 0.3s; }
    .gear-card:hover .card-desc { color: #ddd; }

    /* MODAL (はみ出しボタン対応) */
    .modal-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.9); z-index: 99999;
        display: none; justify-content: center; align-items: center;
        opacity: 0; backdrop-filter: blur(10px);
    }
    .modal-window {
        width: 80vw; max-width: 900px; height: 80vh; max-height: 700px;
        background: #111; border: 4px solid var(--c-text); padding: 0;
        display: grid; grid-template-columns: 1fr 1fr; 
        box-shadow: 0 0 50px rgba(255,255,255,0.2);
        border-radius: 20px; transform: scale(0.8);
        position: relative;
        /* overflow: hiddenを解除してボタンをはみ出させる */
        overflow: visible; 
    }
    
    /* 角丸を適用するために内部要素をクリップ */
    .modal-img-area {
        /* background set by JS */
        display: flex; justify-content: center; align-items: center;
        padding: 40px; position: relative;
        border-top-left-radius: 16px; border-bottom-left-radius: 16px;
    }
    .modal-img { width: 100%; max-height: 400px; object-fit: contain; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.6)); }
    
    .modal-info-area { 
        /* background set by JS */
        padding: 50px; overflow-y: auto; display: flex; flex-direction: column; justify-content: center; 

</style>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
            window.addEventListener('load', initGear);
        } else {
            initGear();
        }
    });

    function initGear() {
        gsap.registerPlugin(ScrollTrigger);

        // VanillaTilt CDN読み込みチェック
        if (typeof VanillaTilt !== 'undefined') {
            // Tilt Effect
            VanillaTilt.init(document.querySelectorAll(".gear-card"), {
                max: 15,
                speed: 400,
                glare: true,
                "max-glare": 0.3,
            });
        }

        // Custom Cursor
        const cursor = document.querySelector('.cursor');
        const magnets = document.querySelectorAll('.magnet, a, .gear-card, .hamburger-btn');
        const moreSection = document.getElementById('more-section');

        if (cursor) {
            document.addEventListener('mousemove', (e) => {
                gsap.to(cursor, { x: e.clientX, y: e.clientY, duration: 0.1, ease: 'power2.out' });
            });
        }
        
        // カーソル判定（Moreセクション）
        if (moreSection && cursor) {
            moreSection.addEventListener('mouseenter', () => cursor.classList.add('on-green'));
            moreSection.addEventListener('mouseleave', () => cursor.classList.remove('on-green'));
        }

        magnets.forEach(magnet => {
            if (cursor) {
                magnet.addEventListener('mouseenter', () => cursor.classList.add('hovered'));
                magnet.addEventListener('mouseleave', () => cursor.classList.remove('hovered'));
            }
        });

        // Scroll Animations
        gsap.utils.toArray('.reveal').forEach(element => {
            gsap.fromTo(element, 
                { y: 100, opacity: 0 },
                { 
                    y: 0, 
                    opacity: 1, 
                    duration: 1, 
                    ease: 'power4.out',
                    scrollTrigger: {
                        trigger: element,
                        start: 'top 85%',
                    }
                }
            );
        });
        

        // --- DATA PREPARATION ---
        const mainGearCards = document.querySelectorAll('.gear-card');

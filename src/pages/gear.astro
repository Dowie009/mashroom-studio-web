    .marquee { display: inline-block; animation: scroll 30s linear infinite; font-family: var(--font-en); font-size: 2.5rem; font-weight: 900; color: var(--c-black); }
    @keyframes scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    
    .more-grid { 

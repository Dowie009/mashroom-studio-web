---
import Layout from '../layouts/Layout.astro';
---

<Layout title="GEAR LIST | MASHROOM STUDIO">
    <script slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.0/vanilla-tilt.min.js" is:inline></script>
    <div class="bg-grid"></div>

    <a href="/" class="back-link magnet">← HOME</a>

    <!-- COMPACT HEADER -->
    <div class="compact-header">
        <h1 class="header-title">04 GEAR LIST</h1>
        <div class="header-sub">THE WEAPONS FOR YOUR CREATIVITY</div>
    </div>

    <!-- MAIN GEAR SECTION -->
    <div class="gear-section">
        <!-- 01. SOUND SYSTEM -->
        <div class="cat-header reveal">
            <h2 class="cat-title"><span style="color:var(--pop-6);">01</span> SOUND SYSTEM</h2>
            <p class="cat-desc">音の入り口と出口。妥協なき最高峰の環境。</p>
        </div>
        <div class="gear-grid">
            <!-- Mac Studio -->
            <div class="gear-card magnet reveal" data-tilt 
                 data-name="Apple Mac Studio" data-jp="ワークステーション" data-tag="SYSTEM" 
                 data-color="var(--pop-5)" data-img="/img/01Mac.jpg"
                 data-desc="Appleの高性能デスクトップ。M4 Maxチップ搭載で、プロレベルの音楽制作・映像編集に対応。"
                 data-specs="Chip: M4 Max / RAM: 64GB">
                <div class="card-img-box"><img src="/img/01Mac.jpg" alt="Mac Studio" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-5);">SYSTEM</div>
                    <div class="card-name">Mac Studio M4 Max</div>
                    <div class="card-jp">ワークステーション</div>
                    <p class="card-desc">M4 Max搭載。最強の制作環境。</p>
                </div>
            </div>
            <!-- Titan -->
            <div class="gear-card magnet reveal" data-tilt 
                 data-name="Prism Sound Titan" data-jp="オーディオインターフェース" data-tag="INTERFACE" 
                 data-color="var(--pop-4)" data-img="/img/Titan.jpg"
                 data-desc="イギリスの至宝。圧倒的な解像度と音楽的な艶を兼ね備えたAD/DAコンバーター。このスタジオの心臓部。"
                 data-specs="Inputs: 8 Analog, 8 Digital / Dynamic Range: 120dB+">
                <div class="card-img-box"><img src="/img/Titan.jpg" alt="Prism Sound Titan" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-4);">INTERFACE</div>
                    <div class="card-name">Prism Sound Titan</div>
                    <div class="card-jp">オーディオインターフェース</div>
                    <p class="card-desc">イギリスの至宝。圧倒的な解像度。</p>
                </div>
            </div>
             <!-- Apollo x4 -->
             <div class="gear-card magnet reveal" data-tilt 
                 data-name="Universal Audio Apollo x4" data-jp="オーディオインターフェース" data-tag="SUB IF" 
                 data-color="var(--pop-3)" data-img="/img/02X4.jpg"
                 data-desc="UADプラグインをリアルタイム処理できる12in/18out Thunderbolt 3対応I/F。プロスタジオ品質の音質。"
                 data-specs="DSP: UAD-2 Quad Core / Preamps: 4 Unison Preamps">
                <div class="card-img-box"><img src="/img/02X4.jpg" alt="Apollo x4" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-3);">SUB IF</div>
                    <div class="card-name">Apollo x4</div>
                    <div class="card-jp">オーディオインターフェース</div>
                    <p class="card-desc">UADプロセッシング対応のサブ機。</p>
                </div>
            </div>
            <!-- Genelec -->
            <div class="gear-card magnet reveal" data-tilt
                 data-name="Genelec 8351A" data-jp="スタジオモニタースピーカー" data-tag="MONITOR"
                 data-color="var(--pop-2)" data-img="/img/Genelec8351A.jpg"
                 data-desc="Genelecの3ウェイ同軸モニター。GLM自動音場補正機能により、正確なミックス環境を実現。"
                 data-specs="Type: 3-Way Coaxial / SPL: 111dB / Power: 200V駆動">
                <div class="card-img-box"><img src="/img/Genelec8351A.jpg" alt="Genelec 8351A" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-2);">MONITOR</div>
                    <div class="card-name">Genelec 8351A</div>
                    <div class="card-jp">スタジオモニタースピーカー</div>
                    <p class="card-desc">200V電源駆動の同軸3Wayモニター。</p>
                </div>
            </div>
        </div>

        <!-- 02. ANALOG & MIC -->
        <div class="cat-header reveal">
            <h2 class="cat-title"><span style="color:var(--pop-1);">02</span> ANALOG & MIC</h2>
            <p class="cat-desc">音楽の魔法。空気感を切り取る極上の機材。</p>
        </div>
        <div class="gear-grid">
            <!-- Pure Tube -->
            <div class="gear-card magnet reveal" data-tilt
                 data-name="LEWITT PURE TUBE" data-jp="真空管コンデンサーマイク" data-tag="MAIN MIC"
                 data-color="var(--pop-1)" data-img="/img/LEWITTPureTube.jpg"
                 data-desc="真空管を使用した大型コンデンサーマイク。温かみのあるボーカル録音に適する。"
                 data-specs="Type: Tube Condenser / Main Vocal Use">
                <div class="card-img-box"><img src="/img/LEWITTPureTube.jpg" alt="LEWITT PURE TUBE" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-1);">MAIN MIC</div>
                    <div class="card-name">LEWITT PURE TUBE</div>
                    <div class="card-jp">真空管コンデンサーマイク</div>
                    <p class="card-desc">ノイズレスかつ温かい、モダンな真空管サウンド。</p>
                </div>
            </div>
             <!-- SM58 -->
             <div class="gear-card magnet reveal" data-tilt
                 data-name="Shure SM58" data-jp="ダイナミックマイク" data-tag="STANDARD"
                 data-color="#555555" data-img="/img/08 58.jpg"
                 data-desc="世界標準のライブ用ボーカルマイク。耐久性が高く、幅広い用途に対応。"
                 data-specs="Type: Dynamic / Pattern: Cardioid">
                <div class="card-img-box"><img src="/img/08 58.jpg" alt="Shure SM58" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:#555555; color:white;">STANDARD</div>
                    <div class="card-name">Shure SM58</div>
                    <div class="card-jp">ダイナミックマイク</div>
                    <p class="card-desc">世界標準のダイナミックマイク。</p>
                </div>
            </div>
            <!-- Fusion -->
            <div class="gear-card magnet reveal" data-tilt
                 data-name="SSL The Fusion" data-jp="アナログプロセッサー" data-tag="PROCESSOR"
                 data-color="var(--pop-4)" data-img="/img/SSL FUSION.jpg"
                 data-desc="2ミックスにアナログの「旨味」を加える魔法の箱。Vintage DriveとViolet EQで楽曲が生き生きと動き出します。"
                 data-specs="Features: Vintage Drive, Violet EQ, HF Compressor">
                <div class="card-img-box"><img src="/img/SSL FUSION.jpg" alt="SSL Fusion" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-4); color:white;">PROCESSOR</div>
                    <div class="card-name">SSL The Fusion</div>
                    <div class="card-jp">アナログプロセッサー</div>
                    <p class="card-desc">2ミックスにアナログの「旨味」を加える魔法の箱。</p>
                </div>
            </div>
            <!-- Bluey -->
            <div class="gear-card magnet reveal" data-tilt
                 data-name="BLA Bluey" data-jp="1176系コンプレッサー" data-tag="COMPRESSOR"
                 data-color="var(--pop-5)" data-img="/img/BlackLionAudioBluey.jpg"
                 data-desc="Chris Lord-Alge愛用機を再現。ボーカルをオケの最前列に「張り付かせる」アグレッシブなサウンド。"
                 data-specs="Type: FET Limiting Amplifier / Ratio: 4:1, 8:1, 12:1, 20:1">
                <div class="card-img-box"><img src="/img/BlackLionAudioBluey.jpg" alt="BLA Bluey" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-5); color:black;">COMPRESSOR</div>
                    <div class="card-name">BLA Bluey</div>
                    <div class="card-jp">1176系コンプレッサー</div>
                    <p class="card-desc">ボーカルを張り付かせるアグレッシブなサウンド。</p>
                </div>
            </div>
        </div>

        <!-- 03. VISUAL & CONTROL -->
        <div class="cat-header reveal">
            <h2 class="cat-title"><span style="color:var(--pop-5);">03</span> VISUAL & CONTROL</h2>
            <p class="cat-desc">4K撮影から配信まで。クリエイティブを加速させる。</p>
        </div>
        <div class="gear-grid">
             <!-- Camera Main -->
             <div class="gear-card magnet reveal" data-tilt
                 data-name="FUJIFILM X-T4" data-jp="ミラーレスカメラ" data-tag="MAIN CAM"
                 data-color="var(--c-text)" data-img="/img/06XT4.jpeg"
                 data-desc="富士フイルムのAPS-Cミラーレスカメラ。動画撮影に強く、配信やMV制作に対応。"
                 data-specs="Sensor: APS-C / Lens: FUJINON XF 33mm F1.4">
                <div class="card-img-box"><img src="/img/06XT4.jpeg" alt="FUJIFILM X-T4" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--c-text); color:black;">MAIN CAM</div>
                    <div class="card-name">FUJIFILM X-T4</div>
                    <div class="card-jp">ミラーレスカメラ</div>
                    <p class="card-desc">4K撮影からライブ配信まで対応。FUJINON XF 33mmレンズ搭載。</p>
                </div>
            </div>
            <!-- Monitor -->
            <div class="gear-card magnet reveal" data-tilt
                 data-name="JAPANNEXT JN-QOLC49" data-jp="49インチ有機ELウルトラワイド" data-tag="DISPLAY"
                 data-color="var(--pop-5)" data-img="/img/JAPANNEXT Ultra Wide.jpg"
                 data-desc="49インチ有機ELウルトラワイドモニター。広い作業領域で、DAWの複数トラックや映像編集を快適に表示。"
                 data-specs="Size: 49 inch / Resolution: 5120x1440 / Panel: OLED">
                <div class="card-img-box"><img src="/img/JAPANNEXT Ultra Wide.jpg" alt="Ultra Wide Monitor" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-5);">DISPLAY</div>
                    <div class="card-name">JAPANNEXT 49" OLED</div>
                    <div class="card-jp">有機ELウルトラワイド</div>
                    <p class="card-desc">49インチ有機EL。圧倒的な作業領域で制作効率を最大化。</p>
                </div>
            </div>
            <!-- ATEM Mini -->
            <div class="gear-card magnet reveal" data-tilt
                 data-name="ATEM Mini" data-jp="ビデオスイッチャー" data-tag="SWITCHER"
                 data-color="var(--pop-3)" data-img="/img/07ATEMMINIPro.jpg"
                 data-desc="コンパクトなライブ配信用スイッチャー。複数カメラ映像を切り替えながら配信可能。"
                 data-specs="Inputs: 4 HDMI / Output: USB Webcam, HDMI">
                <div class="card-img-box"><img src="/img/07ATEMMINIPro.jpg" alt="ATEM Mini" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-3);">SWITCHER</div>
                    <div class="card-name">ATEM Mini</div>
                    <div class="card-jp">ビデオスイッチャー</div>
                    <p class="card-desc">映像切替機材。マルチカメラ配信の必需品。</p>
                </div>
            </div>
             <!-- Stream Deck -->
             <div class="gear-card magnet reveal" data-tilt
                 data-name="Stream Deck XL" data-jp="マクロコントローラー" data-tag="CONTROL"
                 data-color="var(--pop-6)" data-img="/img/05Deck.webp"
                 data-desc="32個のカスタマイズ可能なボタンを搭載。DAW操作、配信、SNS投稿などをワンタッチで実行。"
                 data-specs="Keys: 32 LCD Keys / Connection: USB">
                <div class="card-img-box"><img src="/img/05Deck.webp" alt="Stream Deck XL" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-6); color:black;">CONTROL</div>
                    <div class="card-name">Stream Deck XL</div>
                    <div class="card-jp">マクロコントローラー</div>
                    <p class="card-desc">配信や編集の効率を爆上げする32キーデバイス。</p>
                </div>
            </div>
            <!-- Komplete Kontrol -->
             <div class="gear-card magnet reveal" data-tilt
                 data-name="KOMPLETE KONTROL S61" data-jp="MIDIキーボード" data-tag="KEYBOARD"
                 data-color="var(--pop-4)" data-img="/img/04S61.webp"
                 data-desc="61鍵MIDIコントローラー。KOMPLETEシリーズとの統合制御、カラーガイド機能でスムーズな演奏・入力が可能。"
                 data-specs="Keys: 61 Fatar / Features: Light Guide, NKS">
                <div class="card-img-box"><img src="/img/04S61.webp" alt="KOMPLETE KONTROL S61" class="card-img"></div>
                <div class="card-content">
                    <div class="card-tag" style="background:var(--pop-4);">KEYBOARD</div>
                    <div class="card-name">KOMPLETE KONTROL S61</div>
                    <div class="card-jp">MIDIキーボード</div>
                    <p class="card-desc">NI製MIDIキーボード。制作の中核。</p>
                </div>
            </div>
        </div>
    </div>

    <!-- NAVIGATION HUB -->
    <section style="background: var(--c-bg); padding: 50px 5% 60px; position: relative; z-index: 10; border-bottom: 1px solid #333;">
        <div style="max-width: 1400px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; gap: 30px; flex-wrap: wrap;">
            <h2 style="font-family: var(--font-en); font-size: 2.5rem; color: #666; margin: 0; letter-spacing: 0.1em;">04. GEAR LIST</h2>
            <div style="display: flex; justify-content: center; align-items: center; gap: 20px; flex-wrap: wrap;">
                <a href="/" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid #444; border-radius: 30px; transition: 0.3s; background: rgba(0,0,0,0.5);">00. HOME</a>
                <a href="/profile" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid #444; border-radius: 30px; transition: 0.3s; background: rgba(0,0,0,0.5);">01. PROFILE</a>
                <a href="/works" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid #444; border-radius: 30px; transition: 0.3s; background: rgba(0,0,0,0.5);">02. WORKS</a>
                <a href="/lesson" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid #444; border-radius: 30px; transition: 0.3s; background: rgba(0,0,0,0.5);">03. LESSON</a>
                <a href="/gear" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid #444; border-radius: 30px; transition: 0.3s; background: rgba(0,0,0,0.5); opacity: 0.5; pointer-events: none;">04. GEAR</a>
                <a href="/price" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid #444; border-radius: 30px; transition: 0.3s; background: rgba(0,0,0,0.5);">05. PRICE</a>
                <a href="https://xn--3-sj5c.jp/blog/" class="hub-link magnet" target="_blank" rel="noopener noreferrer" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid #444; border-radius: 30px; transition: 0.3s; background: rgba(0,0,0,0.5);">06. BLOG</a>
                <a href="/#contact" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid #444; border-radius: 30px; transition: 0.3s; background: rgba(0,0,0,0.5);">07. CONTACT</a>
            </div>
        </div>
    </section>

    <!-- MORE GEARS -->
    <section class="more-gears" id="more-section">
        <div class="marquee-wrap">
            <div class="marquee">
                MORE GEARS /// PLUGINS /// INSTRUMENTS /// CABLES /// MICROPHONES /// MORE GEARS /// PLUGINS /// INSTRUMENTS /// CABLES /// MICROPHONES ///
            </div>
        </div>
        
        <div class="container" style="text-align:center; margin-bottom:40px;">
            <h2 style="font-family:var(--font-en); font-size:4rem; line-height:0.9; text-shadow:0 0 20px var(--c-white);">AND MORE...</h2>
            <p style="font-weight:bold;">まだまだあります。クリエイティビティを刺激する機材たち。<br>(クリックで詳細を表示)</p>
        </div>

        <div class="more-grid reveal" id="more-grid">
            <!-- JSで生成 -->
        </div>
    </section>

    <!-- MODAL WINDOW -->
    <div class="modal-overlay" id="modal-overlay">
        
        <!-- NAVIGATION BUTTONS (OUTSIDE MODAL) -->
        <div class="modal-nav-btn modal-prev" id="modal-prev">◀ BACK</div>
        <div class="modal-nav-btn modal-next" id="modal-next">NEXT ▶</div>

        <div class="modal-window" id="modal-window">
            <div class="modal-close" id="modal-close">×</div>
            
            <div class="modal-img-area" id="modal-img-area">
                <img src="" alt="" class="modal-img" id="modal-img">
            </div>
            <div class="modal-info-area" id="modal-info-area">
                <div class="modal-tag" id="modal-tag">TAG</div>
                <h3 class="modal-title" id="modal-title">GEAR NAME</h3>
                <p class="modal-jp" id="modal-jp">機材名</p>
                <p class="modal-desc" id="modal-desc">説明文がここに入ります。</p>
                <div class="modal-specs" id="modal-specs">SPECS: ...</div>
            </div>
        </div>
    </div>

    <footer>
        <p>&copy; 2025 MASHROOM STUDIO by Walewalewa</p>
    </footer>
</Layout>

<style is:global>
    :root {
        --c-bg: #111111;
        --c-text: #ffffff;
        --c-black: #000000;
    }

    /* BG GRID */
    .bg-grid {
        position: fixed; top: 0; left: 0; width: 200%; height: 200%; z-index: -1;
        background-image: 
            linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 60px 60px;
        transform: perspective(500px) rotateX(60deg) translateY(-100px) translateZ(-200px);
        animation: grid-move 20s linear infinite;
        pointer-events: none;
    }
    @keyframes grid-move { 0% { transform: perspective(500px) rotateX(60deg) translateY(0) translateZ(-200px); } 100% { transform: perspective(500px) rotateX(60deg) translateY(60px) translateZ(-200px); } }

    /* カーソル（ページ固有） */
    .cursor.on-modal { width: 40px; height: 40px; background: var(--pop-1); border: 2px solid white; mix-blend-mode: normal; opacity: 1; }
    
    /* 緑背景上のカーソル */
    .cursor.on-green {
        mix-blend-mode: normal;
        background: transparent;
        border: 3px solid var(--c-black);
        width: 30px; height: 30px;
    }
    .cursor.on-green.hovered {
        background: rgba(0,0,0,0.1);
        width: 80px; height: 80px;
        border-width: 1px;
    }

    /* NAV */
    .back-link { position: absolute; top: 30px; left: 30px; z-index: 100; font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; border: 2px solid var(--c-text); padding: 10px 20px; border-radius: 30px; transition: 0.3s; background: rgba(0,0,0,0.5); }
    .back-link:hover { background: var(--c-text); color: var(--c-black); }

    .hamburger-btn { position: fixed; top: 30px; right: 30px; z-index: 11000; width: 80px; height: 80px; background: var(--c-text); border: 4px solid var(--pop-2); border-radius: 12px; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 6px; cursor: pointer; transition: 0.3s; }
    /* 回転はJSに任せるためCSSのhover回転を削除 */
    .hamburger-btn:hover { background: var(--pop-2); border-color: var(--c-black); }
    .hamburger-btn:hover .h-line { background: var(--c-black); }
    .h-line { width: 40px; height: 4px; background: var(--c-black); transition: 0.3s; border-radius: 2px; }
    
    .pop-sidebar { position: fixed; top: 0; right: 0; width: 100%; max-width: 500px; height: 100vh; background: rgba(0,0,0,0.95); border-left: 4px solid var(--pop-2); z-index: 10500; transform: translateX(100%); display: flex; flex-direction: column; justify-content: center; padding: 40px; transition: 0.5s cubic-bezier(0.77, 0, 0.175, 1); }
    .pop-sidebar.is-open { transform: translateX(0); }
    .menu-item { list-style: none; margin: 20px 0; text-align: right; }
    .menu-link { font-family: var(--font-en); font-size: 3rem; color: var(--c-text); text-decoration: none; transition: 0.3s; }
    .menu-link:hover { color: var(--pop-2); letter-spacing: 5px; text-shadow: 0 0 20px var(--pop-2); }


    /* COMPACT HEADER */
    .compact-header {
        padding: 150px 5% 80px;
        display: flex; flex-direction: column; justify-content: center; align-items: center;
        position: relative; text-align: center;
    }
    .header-title {
        font-size: 10rem; font-family: var(--font-en); line-height: 0.8; color: var(--c-white);
        text-transform: uppercase; text-shadow: 0 0 30px rgba(255,255,255,0.5);
        margin-bottom: 20px;
    }
    .header-sub {

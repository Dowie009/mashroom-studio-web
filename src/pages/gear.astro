        border-top-right-radius: 16px; border-bottom-right-radius: 16px;
    }
    
    .modal-tag { display: inline-block; background: var(--c-black); color: var(--c-white); padding: 5px 15px; font-weight: bold; font-family: var(--font-en); margin-bottom: 20px; width: fit-content; }
    .modal-title { font-size: 3.5rem; font-family: var(--font-en); line-height: 0.9; margin-bottom: 10px; word-wrap: break-word; color: var(--c-black) !important; }
    .modal-jp { font-size: 1.2rem; color: #444; margin-bottom: 30px; font-family: var(--font-digi); font-weight: bold; }
    .modal-desc { font-size: 1.1rem; line-height: 1.8; color: #222; margin-bottom: 30px; border-top: 2px solid var(--c-black); padding-top: 20px; font-weight: 500; }
    .modal-specs { font-size: 0.9rem; color: #333; font-family: monospace; white-space: pre-wrap; background: rgba(255,255,255,0.5); padding: 10px; border-radius: 4px; }
    
    .modal-close {
        position: absolute; top: -25px; right: -25px; /* 枠外へ */
        width: 50px; height: 50px; background: var(--c-black); color: var(--c-white);
        border: 3px solid var(--c-white); border-radius: 50%;
        display: flex; justify-content: center; align-items: center;
        font-size: 2rem; cursor: pointer; transition: 0.2s; z-index: 100;
    }
    .modal-close:hover { background: var(--pop-1); border-color: var(--pop-1); transform: rotate(90deg); }

    /* MODAL NAVIGATION BUTTONS (OUTSIDE & ELECTRIC) */
    .modal-nav-btn {
        position: absolute; top: 50%; transform: translateY(-50%);
        background: var(--c-black); 
        font-family: var(--font-en); font-size: 2rem; font-weight: 900;
        padding: 20px 40px; 
        border-width: 3px; border-style: solid;
        border-radius: 10px;
        cursor: pointer; z-index: 10000; /* 最前面 */
        display: flex; align-items: center; gap: 15px;
        text-transform: uppercase;
        transition: all 0.1s;
        pointer-events: auto; 
    }
    .modal-prev { 
        left: -30px; /* 枠に少しかかる位置に変更 */
        color: var(--pop-6); /* 黄色 */
        border-color: var(--pop-6);
        box-shadow: 0 0 15px var(--pop-6);
    } 
    .modal-next { 
        right: -30px; /* 枠に少しかかる位置に変更 */
        color: var(--pop-5); /* 水色 */
        border-color: var(--pop-5);
        box-shadow: 0 0 15px var(--pop-5);
    } 
    
    @keyframes electric-shock {
        0% { transform: translateY(-50%) translate(0, 0) rotate(0deg); filter: hue-rotate(0deg); }
        25% { transform: translateY(-50%) translate(-3px, 3px) rotate(-2deg); }
        50% { transform: translateY(-50%) translate(3px, -3px) rotate(2deg); filter: hue-rotate(90deg); }
        75% { transform: translateY(-50%) translate(-3px, -3px) rotate(-1deg); }
        100% { transform: translateY(-50%) translate(3px, 3px) rotate(1deg); filter: hue-rotate(0deg); }

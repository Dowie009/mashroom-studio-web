<script is:inline>
    // GSAPはLayout.astroでCDNから読み込まれているので、DOMContentLoadedで実行
    document.addEventListener('DOMContentLoaded', () => {
        // GSAPの読み込みを待つ
        function waitForGSAP() {
            if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
                initProfile();
            } else {
                setTimeout(waitForGSAP, 50);
            }
        }
        waitForGSAP();
    });

    function initProfile() {
        if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);
        }

        // --- POEM MODAL 関数定義（最優先で定義） ---
        const poemModalOverlay = document.getElementById('poem-modal-overlay');
        const poemCard = document.getElementById('poem-card');
        const poemTitle = document.getElementById('poem-title');
        const poemText = document.getElementById('poem-text');
        const poemNote = document.getElementById('poem-note');
        const poemClose = document.getElementById('poem-close');
        
        function openPoem(term, poem, note = "") {
            if (!poemTitle || !poemText || !poemModalOverlay) return;
            poemTitle.innerText = term;
            poemText.innerText = poem;
            if (note) {
                if (poemNote) {
                    poemNote.innerText = note;
                    poemNote.style.display = "block";
                }
            } else {
                if (poemNote) {
                    poemNote.style.display = "none";
                }
            }
            poemModalOverlay.style.display = 'flex';
            gsap.to(poemCard, { scale: 1, opacity: 1, duration: 0.4, ease: "back.out(1.7)" });
        }

        function closePoem() {
            gsap.to(poemCard, { scale: 0.8, opacity: 0, duration: 0.3, ease: "power2.in", onComplete: () => { if (poemModalOverlay) poemModalOverlay.style.display = 'none'; }});
        }
        
        // POEMモーダルのイベントリスナー
        if (poemClose) {
            poemClose.addEventListener('click', closePoem);
        }
        if (poemModalOverlay) {
            poemModalOverlay.addEventListener('click', (e) => { if (e.target === poemModalOverlay) closePoem(); });
        }
        
        // --- カーソル、マグネット、GSAP共通設定 ---
        const cursor = document.querySelector('.cursor');
        const magnets = document.querySelectorAll('.magnet, .kinetic-item');
        if (cursor) {
            document.addEventListener('mousemove', (e) => { gsap.to(cursor, { x: e.clientX, y: e.clientY, duration: 0.1 }); });
        }
        magnets.forEach(magnet => {
            if (cursor) {
                magnet.addEventListener('mouseenter', () => cursor.classList.add('hovered'));
                magnet.addEventListener('mouseleave', () => cursor.classList.remove('hovered'));
            }
        });
        
        gsap.utils.toArray('.reveal-text').forEach(element => {
            gsap.fromTo(element, { y: 50, opacity: 0 }, { y: 0, opacity: 1, duration: 0.8, ease: 'power2.out', scrollTrigger: { trigger: element, start: 'top 85%' } });
        });
        
        // --- キネティックストリーム（WORKS）のアニメーション ---
        const track = document.querySelector('.kinetic-track');
        if (track) {
            gsap.to(track, { xPercent: -50, ease: "none", duration: 20, repeat: -1 });
        }
        
        const wrapper = document.querySelector('.kinetic-stream-wrapper');
        if (wrapper && track) {
            wrapper.addEventListener('mouseenter', () => { gsap.to(track, { timeScale: 0.2, duration: 0.5 }); });
            wrapper.addEventListener('mouseleave', () => { gsap.to(track, { timeScale: 1, duration: 0.5 }); });
        }

        // ハンバーガーメニューはcommon.jsで処理されるため、ここでは不要

        // FAVORITES Data & Generation
        const favorites = [
            { term: "本田珈琲のブラジルショコラの豆", poem: "ここ激やば。。。\n完全自家焙煎、仙人級の\nスペシャリティ", note: "札幌市中央区南16条西14-1-23" },
            { term: "一発OK", poem: "神様が降りてきた瞬間\n二度と同じテイクは録れない\n奇跡の真空パック" },
            { term: "アーティストのギアが入った瞬間", poem: "空気が変わる\n鳥肌が立つ\nこの瞬間のために生きている" },
            { term: "オーディオインターフェースのLEDランプ", poem: "静寂の中で瞬く\n音の鼓動\n緑から赤へ、感情の振れ幅" },
            { term: "クライアントの「最高です！」", poem: "すべての疲れが吹き飛ぶ\n魔法の言葉\n次もまた、最高を超えよう" },
            { term: "コメダ珈琲のお持ち帰りの豆", poem: "日常の相棒\n変わらない味\nホッとするひととき" },
            { term: "スピード感のある人", poem: "録音もナマモノ\nNot!ナマケモノ！" },
            { term: "DTMの深夜作業", poem: "世界が眠る頃\nモニターの光だけが\n僕の宇宙を照らす" },
            { term: "パスの回るフットサル", poem: "言葉はいらない\n呼吸が合う\n美しい連携の芸術" },
            { term: "ハードグミと炭酸水", poem: "噛みしめる刺激\n弾ける爽快感\n脳を目覚めさせる最強コンビ" },
            { term: "MINTIA COLD SMASH", poem: "一粒の覚醒\n冷たい風が吹き抜ける\nリセットボタン" },
            { term: "Mac製品の箱開け", poem: "完璧な密閉\nゆっくりと開く蓋\n新しい未来の匂い" },
            { term: "ミックス作業前のコーヒー", poem: "感覚を研ぎ澄ます\n黒い液体\nさあ、音の波へ飛び込もう" },
            { term: "ボーカルの一発録り", poem: "緊張と緩和\n魂の叫び\n嘘のない歌が一番響く" },
            { term: "モニタースピーカーの正確さ", poem: "嘘をつかない鏡\n良いも悪いも\n全てを映し出す" },
            { term: "音楽制作の締め切り前の集中力", poem: "ゾーンに入る\n時間が消える\n限界のその先へ" },
            { term: "完成した楽曲の初聴き", poem: "生まれたての音\n世界で一番最初の\nリスナーになる喜び" },
            { term: "寮生活とMTR", poem: "布団にくるまって\nドキドキしたなぁ\n無限の夢" },
            { term: "新しい出会い", poem: "探り合いも\n大事な時間\n緊張がほどける音も録る" },
            { term: "新しいプラグインの発見", poem: "ほとんど試してきた\n世界の技術者はどんな夢を\nみさせてくれる？" },
            { term: "世紀末の詩", poem: "終わらないのが愛だって\n変わらないのが愛だって\n思い出にできないのが愛だって\n100万回恋しても、決してたどり着けない…", note: "TBSの伝説のドラマ" },
            { term: "石山通り（簾舞あたり）", poem: "高校の頃\n寮に戻らなくちゃいけない\n今では懐かしい思い出" },
            { term: "東京-札幌間の飛行機", poem: "死ぬかもしれない、、\n遺書も書く　歌詞として書く\n途中で大体、寝ちゃってる" },
            { term: "野島伸司のドラマ", poem: "偉大な脚本家\n絶望が嫌いじゃないのは\nこの人のおかげかも" },
            { term: "寝巻きで行くコンビニ", poem: "背徳感と自由の味" },
            { term: "ヘッドフォンの新品感", poem: "耳のソファー\nパッドはなるべく新しくしておきます" },
            { term: "レコーディングブースの静寂", poem: "音が消える場所\n心臓の音だけが響く\n聖域" },
            { term: "留寿都高校の憂鬱な思い出", poem: "人生の歪みを知った\n逃げ出したかったあの日々も\n今の僕を作る一部" }
        ];

        const favContainer = document.getElementById('fav-cloud');
        
        if (!favContainer) {
            console.error('❌ ERROR: fav-cloud要素が見つかりません！');
            return;
        }
        
        favContainer.innerHTML = '';
        
        favorites.forEach((item, index) => {
            const span = document.createElement('span');
            span.textContent = item.term;
            span.classList.add('fav-tag');
            span.classList.add('magnet');
            
            // ランダムなサイズと回転
            const size = 0.9 + Math.random() * 0.4;
            span.style.fontSize = `${size}rem`;
            const rotate = -5 + Math.random() * 10;
            span.style.transform = `rotate(${rotate}deg)`;
            
            span.addEventListener('click', () => {
                openPoem(item.term, item.poem, item.note);
            });

            // GSAPアニメーション（ふわふわした動き）
            if (typeof gsap !== 'undefined') {
                gsap.to(span, {
                    y: -10 + Math.random() * 20, 
                    duration: 2 + Math.random() * 2, 
                    repeat: -1,
                    yoyo: true,
                    ease: "sine.inOut",
                    delay: Math.random() * 2
                });
            }

            favContainer.appendChild(span);
        });
    }
</script>

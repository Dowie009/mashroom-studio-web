<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        function waitForGSAP() {
            if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
                initWorks();
            } else {
                setTimeout(waitForGSAP, 50);
            }
        }
        waitForGSAP();
    });

    function initWorks() {
        if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
            gsap.registerPlugin(ScrollTrigger);
        }

        // --- モーダル・タグ・カーソルの基本ロジック ---
        const tagDictionary = {
            "REC": { title: "RECORDING", desc: "ボーカルや楽器のレコーディング。アーティストのパフォーマンスを最大限に引き出し、最高音質でキャプチャします。" },
            "MIX": { title: "MIXING", desc: "録音された各トラックの音量や音質バランスを整え、楽曲として完成させる工程。立体感のあるサウンドを作ります。" },
            "MASTERING": { title: "MASTERING", desc: "2MIX音源を最終的なプロダクトとして磨き上げる最終工程。音圧調整や質感統一を行います。" },
            "PRODUCE": { title: "SOUND PRODUCE", desc: "楽曲制作の総指揮。方向性の策定から、アレンジ、レコーディングのディレクションまで行います。" },
            "ARRANGE": { title: "ARRANGEMENT", desc: "編曲。メロディとコード進行を元に、楽曲の彩りとドラマ性を生み出します。" },
            "ANTHEM": { title: "ANTHEM", desc: "チームや団体のための公式楽曲制作。一体感を生むための力強いサウンドを制作します。" },
            "SOUND LOGO": { title: "SOUND LOGO", desc: "企業やブランドの音のロゴ。短い時間で強烈な印象を残すサウンドデザインを行います。" },
            "COMPOSE": { title: "COMPOSITION", desc: "作曲。メロディやハーモニー、リズムの骨組みを作り、楽曲の基礎を築きます。" },
            "MANIPULATE": { title: "MANIPULATION", desc: "シンセサイザーやシーケンサーを用いた音色制作、プログラミング、サウンドエフェクトの構築などを行います。" },
            "WEB CM BGM": { title: "WEB CM BGM", desc: "WebCMのためのBGM制作。映像の意図や世界観に寄り添い、効果的な音響演出を行います。" },
            "GUITAR": { title: "GUITAR", desc: "ギター演奏。スタジオワークからライブサポートまで、楽曲に最適なプレイを提供します。" }
        };

        const modalOverlay = document.getElementById('modal-overlay');
        const modalClose = document.getElementById('modal-close');
        const modalContentArea = document.getElementById('modal-content-area');
        const modalImageArea = document.getElementById('modal-image-area');

        function openModal(htmlContent, imgSrc = null) {
            if (!modalContentArea || !modalOverlay) return;
            modalContentArea.innerHTML = htmlContent;
            if (imgSrc && modalImageArea) {
                const finalImgSrc = imgSrc.startsWith('/img/') ? imgSrc : '/img/' + imgSrc.replace('img/', '');
                modalImageArea.innerHTML = `<img src="${finalImgSrc}" class="modal-art-image">`;
                modalImageArea.classList.add('active');
            } else {
                if (modalImageArea) {
                    modalImageArea.innerHTML = '';
                    modalImageArea.classList.remove('active');
                }
            }
            modalOverlay.classList.add('active');
        }

        function closeModal() {
            if (!modalOverlay) return;
            modalOverlay.classList.remove('active');
            setTimeout(() => {
                if (modalContentArea) modalContentArea.innerHTML = '';
                if (modalImageArea) {
                    modalImageArea.innerHTML = '';
                    modalImageArea.classList.remove('active');
                }
            }, 400);
        }

        if (modalClose) {
            modalClose.addEventListener('click', closeModal);
        }
        if (modalOverlay) {
            modalOverlay.addEventListener('click', (e) => { if (e.target === modalOverlay) closeModal(); });
        }

        document.querySelectorAll('.work-img-box').forEach(box => {
            box.addEventListener('click', (e) => {
                e.stopPropagation();
                const card = box.closest('.work-card');
                const detailData = card.querySelector('.work-detail-data');
                if (detailData) { 
                    openModal(detailData.innerHTML, detailData.getAttribute('data-img-src')); 
                }
            });
        });

        document.querySelectorAll('.work-tag').forEach(tag => {
            tag.addEventListener('click', (e) => {
                e.stopPropagation();
                const tagKey = tag.getAttribute('data-tag');
                const data = tagDictionary[tagKey];
                const computedStyle = window.getComputedStyle(tag);
                const tagColor = computedStyle.backgroundColor;
                if (data) {
                    const htmlContent = `<span class="modal-tag-label">TERM INFO</span><h3 class="modal-header" style="color:${tagColor}; border-color:${tagColor};">${data.title}</h3><p class="modal-body">${data.desc}</p>`;
                    openModal(htmlContent);
                }
            });
        });

        const cursor = document.querySelector('.cursor');
        const magnets = document.querySelectorAll('.magnet');
        if (cursor) {
            document.addEventListener('mousemove', (e) => { 
                if (typeof gsap !== 'undefined') {
                    gsap.to(cursor, { x: e.clientX, y: e.clientY, duration: 0.1 }); 
                }
            });
        }
        magnets.forEach(magnet => {
            if (cursor) {
                magnet.addEventListener('mouseenter', () => cursor.classList.add('hovered'));
                magnet.addEventListener('mouseleave', () => cursor.classList.remove('hovered'));
            }
        });
        
        if (typeof gsap !== 'undefined') {
            gsap.utils.toArray('.reveal-text').forEach(element => {
                gsap.fromTo(element, { y: 50, opacity: 0 }, { y: 0, opacity: 1, duration: 0.8, ease: 'power2.out', scrollTrigger: { trigger: element, start: 'top 85%' } });
            });

            if (window.innerWidth > 768) {
                gsap.to('.col-1', { y: -100, ease: 'none', scrollTrigger: { trigger: '.works-section', start: 'top bottom', end: 'bottom top', scrub: 1 } });
                gsap.to('.col-2', { y: -50, ease: 'none', scrollTrigger: { trigger: '.works-section', start: 'top bottom', end: 'bottom top', scrub: 1.5 } });
                gsap.to('.col-3', { y: -80, ease: 'none', scrollTrigger: { trigger: '.works-section', start: 'top bottom', end: 'bottom top', scrub: 1.2 } });
            }

            // --- 背景ラインの光アニメーション ---
            const bgLines = document.querySelectorAll('.bg-line');
            const lineColors = ['linear-gradient(90deg, transparent, var(--pop-1), var(--pop-6), transparent)', 'linear-gradient(90deg, transparent, var(--pop-5), var(--pop-2), transparent)', 'linear-gradient(90deg, transparent, var(--pop-4), var(--pop-3), transparent)'];

            bgLines.forEach((line) => {
                const randomColor = lineColors[Math.floor(Math.random() * lineColors.length)];
                line.style.background = randomColor;
                const duration = 5 + Math.random() * 5;
                const delay = Math.random() * 5;
                line.style.setProperty('--after-left', '-100%'); 

                gsap.fromTo(line, 
                    { '--after-left': '-100%' }, 
                    { '--after-left': '200%', duration: duration, repeat: -1, ease: 'none', delay: delay }
                );
            });
        }
    }
</script>

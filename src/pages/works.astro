    .pop-sidebar { position: fixed; top: 0; right: 0; width: 500px; max-width: 90vw; height: 100vh; background: rgba(255, 255, 255, 0.95); border-left: 8px solid var(--c-text); z-index: 10500; transform: translateX(120%) skewX(-5deg); transform-origin: top right; box-shadow: -20px 0 50px rgba(0,0,0,0.5); display: flex; flex-direction: column; justify-content: center; padding: 40px; background-image: radial-gradient(var(--pop-5) 2px, transparent 2px); background-size: 30px 30px; }

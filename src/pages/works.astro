    /* 青ズレのアニメーション（静 → 動） */
    .logo-glitch-2 {
        filter: drop-shadow(-4px 0px 0px rgba(0, 255, 255, 0.7)); 
        animation: glitch-anim-2 4s infinite;
    }

    /* グリッチアニメーション定義：ほとんどの時間(0-90%)は何もしない */
    @keyframes glitch-anim-1 {
        0%, 92% { opacity: 0; transform: translate(0); }
        93% { opacity: 0.8; transform: translate(4px, -2px); }
        94% { opacity: 0.8; transform: translate(-2px, 2px); }
        95% { opacity: 0; transform: translate(0); }
        96% { opacity: 0.8; transform: translate(-3px, -1px); }
        97% { opacity: 0; transform: translate(0); }
        100% { opacity: 0; transform: translate(0); }
    }

    @keyframes glitch-anim-2 {
        0%, 92% { opacity: 0; transform: translate(0); }
        93% { opacity: 0.8; transform: translate(-4px, 2px); }
        94% { opacity: 0.8; transform: translate(2px, -2px); }
        95% { opacity: 0; transform: translate(0); }

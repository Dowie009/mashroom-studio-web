    .menu-item:nth-child(3) .menu-link:hover { color: var(--pop-3); text-shadow: 5px 5px 0px var(--c-text); transform: translateX(-20px) scale(1.1); background: var(--c-white); }
    .menu-item:nth-child(4) .menu-link:hover { color: var(--pop-4); text-shadow: 5px 5px 0px var(--c-text); transform: translateX(-20px) scale(1.1); background: var(--c-white); }
    .menu-item:nth-child(5) .menu-link:hover { color: var(--pop-5); text-shadow: 5px 5px 0px var(--c-text); transform: translateX(-20px) scale(1.1); background: var(--c-white); }
    .menu-item:nth-child(6) .menu-link:hover { color: var(--pop-6); text-shadow: 5px 5px 0px var(--c-text); transform: translateX(-20px) scale(1.1); background: var(--c-white); }

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="WORKS & VOICE | MASHROOM STUDIO">
    <div class="bg-lines">
        <div class="bg-line"></div>
        <div class="bg-line"></div>
        <div class="bg-line"></div>
    </div>

    <div class="modal-overlay" id="modal-overlay">
        <div class="modal-content">
            <div class="modal-image-area" id="modal-image-area"></div>
            <div class="modal-text-area">
                <div class="modal-close" id="modal-close">×</div>
                <div id="modal-content-area">
                    <div class="modal-header">TITLE</div>
                    <div class="modal-body">Description...</div>
                </div>
            </div>
        </div>
    </div>

    <header>
        <a href="/" class="logo-container magnet">
            <img src="/img/logo.png" alt="MASHROOM STUDIO" class="logo-img">
            <img src="/img/logo.png" alt="" class="logo-glitch logo-glitch-1">
            <img src="/img/logo.png" alt="" class="logo-glitch logo-glitch-2">
        </a>
        <a href="/" class="back-btn magnet">← BACK TO HOME</a>
    </header>

    <div class="container">
        <h1 class="page-title reveal-text">WORKS &<br>VOICE</h1>
        <p class="page-desc reveal-text">
            MASHROOM STUDIOで生まれた作品たち。<br>
            <span style="font-size:0.9rem; color:#666;">※写真やタグをクリックすると詳細が表示されます</span>
        </p>

        <section class="works-section">
            <h2 class="section-header reveal-text">WORKS</h2>
            
            <div class="parallax-wrapper">
                
                <div class="parallax-col col-1">
                    
                    <div class="work-card magnet" style="--hover-color: var(--pop-2);">
                         <div class="work-img-box ratio-banner magnet">
                            <img src="/img/image_a048c4.png" alt="AKTIO" class="work-img" style="transform: scale(1.02);">
                        </div>
                        <div class="work-tags">
                            <span class="work-tag magnet" data-tag="SOUND LOGO" style="background:var(--pop-2); color:var(--c-text);">SOUND LOGO</span>
                            <span class="work-tag magnet" data-tag="MIX" style="background:var(--pop-4);">MIX</span>
                        </div>
                        <div class="work-title">AKTIO</div>
                        <p class="work-desc">Sound Logo Production (Mix & SE)</p>
                        <div class="work-detail-data" data-img-src="/img/image_a048c4.png">
                            <h3 class="modal-header">AKTIO</h3>
                            <p class="modal-body">
                                サウンドロゴ制作。<br>
                                シンプルながら一瞬でインパクトのある<br>
                                サウンドメイクを追求。<br>
                                何パターンも制作しクライアントさんに<br>
                                チョイスしていただくスタイル！
                            </p>
                        </div>
                    </div>

                    <div class="work-card magnet" style="--hover-color: var(--pop-5);">
                        <div class="work-img-box ratio-wide magnet">
                            <img src="/img/image_a03d20.png" alt="Consadole Sapporo" class="work-img" style="transform: scale(1.01);">
                        </div>
                        <div class="work-tags">
                            <span class="work-tag magnet" data-tag="ANTHEM" style="background:var(--pop-5);">ANTHEM</span>
                            <span class="work-tag magnet" data-tag="PRODUCE" style="background:var(--c-text);">PRODUCE</span>
                        </div>
                        <div class="work-title">CONSADOLE SAPPORO</div>
                        <p class="work-desc">Official Anthem Sound Production</p>
                        <div class="work-detail-data" data-img-src="/img/image_a03d20.png">
                            <h3 class="modal-header">CONSADOLE<br>SAPPORO</h3>
                            <p class="modal-body">
                                2023-2024シーズン。<br>
                                2年間にわたるメンバー紹介BGMと<br>
                                会場を煽る映像BGMを担当。<br>
                                札幌ドームを揺らすための<br>
                                ロックを追求しました。
                            </p>
                        </div>
                    </div>

                    <div class="work-card magnet ratio-square-card" style="--hover-color: var(--pop-3);">
                        <div class="work-img-box ratio-cinema magnet">
                            <img src="/img/Chevon.jpg" alt="Chevon" class="work-img" style="transform: scale(1.15);">
                        </div>
                        <div class="work-tags">
                            <span class="work-tag magnet" data-tag="PRODUCE" style="background:var(--c-text);">PRODUCE</span>
                            <span class="work-tag magnet" data-tag="REC" style="background:var(--pop-1);">REC</span>
                            <span class="work-tag magnet" data-tag="MANIPULATE" style="background:var(--pop-4);">MANIPULATE</span>
                        </div>
                        <div class="work-title">Chevon</div>
                        <p class="work-desc">Sound Produce / Rec / Manipulate</p>
                        <div class="work-detail-data" data-img-src="/img/Chevon.jpg">
                            <h3 class="modal-header">Chevon</h3>
                            <p class="modal-body">
                                初期のサウンドプロデュース、<br>
                                レコーディング、マニピュレートを担当。<br>
                                大活躍中のChevon 突き進めー👍<br><br>
                                <a href="https://www.youtube.com/watch?v=g63pjGHhhx0" target="_blank">No.4 (YouTube)</a><br>
                                <a href="https://www.youtube.com/watch?v=iz5cU3yQbn4" target="_blank">Banquet (YouTube)</a>
                            </p>
                        </div>
                    </div>

                </div>

                <div class="parallax-col col-2">
                    
                    <div class="work-card magnet ratio-wide-card" style="--hover-color: var(--pop-2);">
                        <div class="work-img-box ratio-wide magnet">
                            <img src="/img/image_a03568.jpg" alt="TAIGAN" class="work-img">
                        </div>
                        <div class="work-tags">
                            <span class="work-tag magnet" data-tag="COMPOSE" style="background:var(--pop-3);">COMPOSE</span>
                            <span class="work-tag magnet" data-tag="MANIPULATE" style="background:var(--pop-4);">MANIPULATE</span>
                        </div>
                        <div class="work-title">【ドラマ】対岸の家事</div>
                        <p class="work-desc">Drama "Taigan no Kaji" Music Production</p>
                        <div class="work-detail-data" data-img-src="/img/image_a03568.jpg">
                            <h3 class="modal-header">【ドラマ】対岸の家事</h3>
                            <p class="modal-body">
                                flumpoolの阪井一生さんと<br>
                                共同で作曲を行いました。<br>
                                楽曲のマニピュレート<br>
                                （プログラミングや音色制作）も担当。<br>
                                30曲以上作ったりするんです👌<br>
                                <a href="https://www.tbs.co.jp/taigannokaji_tbs/" target="_blank">公式サイト</a>
                            </p>
                        </div>
                    </div>

                    <div class="work-card magnet ratio-square-card" style="--hover-color: var(--pop-6);">
                        <div class="work-img-box ratio-square magnet">
                            <img src="/img/image_a035c2.jpg" alt="Tenma" class="work-img">
                        </div>
                        <div class="work-tags">
                            <span class="work-tag magnet" data-tag="ARRANGE" style="background:var(--pop-3);">ARRANGE</span>
                            <span class="work-tag magnet" data-tag="MIX" style="background:var(--pop-4);">MIX</span>
                        </div>
                        <div class="work-title">【映画】天間荘の三姉妹</div>
                        <p class="work-desc">Full Sound Production</p>
                        <div class="work-detail-data" data-img-src="/img/image_a035c2.jpg">
                            <h3 class="modal-header">【映画】天間荘の三姉妹</h3>
                            <p class="modal-body">
                                巨匠 松本晃彦氏のチームにて<br>
                                1ヶ月半のマニピュレート活動。<br>
                                L.Aとのストリングスレコーディングも<br>
                                経験しました（オンライン）。<br>
                                <a href="https://www.tenmasou.com/" target="_blank">公式サイト</a>
                            </p>
                        </div>
                    </div>

                    <div class="work-card magnet ratio-wide-card" style="--hover-color: var(--pop-1);">
                         <div class="work-img-box ratio-wide magnet">
                            <img src="/img/placeholder_projz.png" alt="Project Z" class="work-img">
                        </div>
                        <div class="work-tags">
                            <span class="work-tag magnet" data-tag="MASTERING" style="background:var(--c-text);">MASTERING</span>
                        </div>
                        <div class="work-title">PROJECT Z</div>
                        <p class="work-desc">Album Mastering</p>
                        <div class="work-detail-data" data-img-src="/img/placeholder_projz.png">
                            <h3 class="modal-header">PROJECT Z</h3>
                            <p class="modal-body">
                                全10曲のアルバムマスタリングを担当。<br>
                                曲ごとのダイナミクスを整えつつ、<br>
                                アルバム全体としての統一感<br>
                                （トーン＆マナー）を意識して仕上げました。<br>
                                配信プラットフォームごとの<br>
                                ラウドネス基準にも準拠させています。
                            </p>
                        </div>
                    </div>

                </div>

                <div class="parallax-col col-3">
                    
                    <div class="work-card magnet ratio-square-card" style="--hover-color: var(--pop-5);">
                        <div class="work-img-box ratio-square magnet">
                            <img src="/img/L_Logo.jpeg" alt="LeTAO" class="work-img">
                        </div>
                        <div class="work-tags">
                            <span class="work-tag magnet" data-tag="WEB CM BGM" style="background:var(--pop-5); color:var(--c-text);">WEB CM BGM</span>
                            <span class="work-tag magnet" data-tag="COMPOSE" style="background:var(--pop-3);">COMPOSE</span>
                        </div>
                        <div class="work-title">LeTAO 小樽洋菓子舗ルタオ</div>
                        <p class="work-desc">Web CM Music Production</p>
                        <div class="work-detail-data" data-img-src="/img/L_Logo.jpeg">
                            <h3 class="modal-header">小樽洋菓子舗ルタオ</h3>
                            <p class="modal-body">
                                WebCMの音楽を3作品担当させていただきました。<br>
                                作曲、ナレーションレコーディング、<br>
                                ミックスまでトータルで<br>
                                音関係を全て制作しています。
                            </p>
                        </div>
                    </div>

                    <div class="work-card magnet ratio-square-card" style="--hover-color: var(--pop-1);">
                        <div class="work-img-box ratio-square magnet">
                            <img src="/img/image_a121e5.jpg" alt="JIN" class="work-img" style="transform: scale(1.05);">
                        </div>
                        <div class="work-tags">
                            <span class="work-tag magnet" data-tag="REC" style="background:var(--pop-1);">REC</span>
                            <span class="work-tag magnet" data-tag="MIX" style="background:var(--pop-4);">MIX</span>
                            <span class="work-tag magnet" data-tag="MANIPULATE" style="background:var(--pop-2); color:var(--c-text);">MANIPULATE</span>
                        </div>
                        <div class="work-title">【積丹スピリット】火の帆 UMI</div>
                        <p class="work-desc">Rec / Mix / Mastering / Manipulate</p>
                        <div class="work-detail-data" data-img-src="/img/image_a121e5.jpg"> 
                            <h3 class="modal-header">【積丹スピリット】火の帆 UMI</h3>
                            <p class="modal-body">
                                楽器録音からミックス、マスタリングまで担当。<br>
                                さらにSEとリズムを足すマニピュレートを行い、<br>
                                楽曲の世界観を拡張しました。<br>
                                トータルサウンドプロデュースに近い<br>
                                関わり方をしています。<br>
                                <a href="https://www.youtube.com/watch?v=-eJu5lWd3G4" target="_blank">YouTubeで聴く</a>
                            </p>
                        </div>
                    </div>

                    <div class="work-card magnet ratio-square-card" style="--hover-color: var(--pop-4);">
                        <div class="work-img-box ratio-square magnet">
                            <img src="/img/unclose.jpg" alt="UNCLOSE" class="work-img">
                        </div>
                        <div class="work-tags">
                            <span class="work-tag magnet" data-tag="LIVE" style="background:var(--pop-6); color:var(--c-text);">LIVE</span>
                            <span class="work-tag magnet" data-tag="GUITAR" style="background:var(--pop-1);">GUITAR</span>
                        </div>
                        <div class="work-title">flumpool tour 2009『Unclose』</div>
                        <p class="work-desc">Support Guitar</p>
                        <div class="work-detail-data" data-img-src="/img/unclose.jpg">
                            <h3 class="modal-header">flumpool tour 2009『Unclose』</h3>
                            <p class="modal-body">
                                flumpool tour 2009『Unclose』Special!!<br>
                                LIVE at 日本武道館〈2枚組〉 [DVD]<br>
                                サポートギターで参加しました。<br>
                                <a href="https://tower.jp/search/item/AZBS-1002/1" target="_blank">Tower Records Online</a>
                            </p>
                        </div>
                    </div>

                </div>

            </div>
        </section>

        <section class="voice-section">
            <div class="voice-bg-shape"></div>
            <h2 class="section-header reveal-text" style="background: var(--c-white); color: var(--c-text); border: 4px solid var(--c-text); box-shadow: 10px 10px 0px var(--pop-6);">VOICE</h2>
            
            <div class="voice-grid">
                <div class="voice-card vc-1 reveal-text">
                    <p class="voice-text">
                        「初めてのレコーディングで緊張していましたが、道ゐさんがとても優しくサポートしてくれて、リラックスして歌えました。出来上がった音源のクオリティに感動しました！」
                    </p>
                    <div class="voice-author">
                        <div class="voice-info">
                            <span class="voice-name">Aさん</span>
                            <span class="voice-attr">シンガーソングライター</span>
                        </div>
                        <div class="voice-icon" style="background:var(--pop-1);"></div>
                    </div>
                </div>

                <div class="voice-card vc-2 reveal-text">
                    <p class="voice-text">
                        「ただ録音するだけでなく、アレンジのアドバイスもいただけて、曲が何倍も良くなりました。まさに『一緒に作る』という感覚で、とても楽しかったです。またお願いします！」
                    </p>
                    <div class="voice-author">
                        <div class="voice-info">
                            <span class="voice-name">Bバンド 様</span>
                            <span class="voice-attr">ロックバンド</span>
                        </div>
                        <div class="voice-icon" style="background:var(--pop-4);"></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="client-section reveal-text">
            <h2 class="section-header" style="background:var(--c-text); color:var(--c-white); box-shadow: 5px 5px 0 var(--pop-2); transform: rotate(1deg); font-size: 2.5rem;">CLIENTS & ARTISTS</h2>
            
            <div class="list-group">
                <h3 class="list-header" style="background: var(--pop-1); box-shadow: 5px 5px 0 var(--c-text);">ARTISTS</h3>
                <div class="client-list">
                    <span class="client-item">Chevon</span><span class="client-sep">/</span>
                    <span class="client-item">EN</span><span class="client-sep">/</span>
                    <span class="client-item">flumpool</span><span class="client-sep">/</span>
                    <span class="client-item">Fubuki</span><span class="client-sep">/</span>
                    <span class="client-item">HELLsy</span><span class="client-sep">/</span>
                    <span class="client-item">HiColor</span><span class="client-sep">/</span>
                    <span class="client-item">KOHEI SHINOHARA</span><span class="client-sep">/</span>
                    <span class="client-item">MiU</span><span class="client-sep">/</span>
                    <span class="client-item">North Sound Signal</span><span class="client-sep">/</span>
                    <span class="client-item">Rihwa</span><span class="client-sep">/</span>
                    <span class="client-item">Tomomi</span><span class="client-sep">/</span>
                    <span class="client-item">TRIPLANE</span><span class="client-sep">/</span>
                    <span class="client-item">小澤ちひろ</span><span class="client-sep">/</span>
                    <span class="client-item">観月</span><span class="client-sep">/</span>
                    <span class="client-item">木歩</span><span class="client-sep">/</span>
                    <span class="client-item">佐藤広大</span><span class="client-sep">/</span>
                    <span class="client-item">しー坊</span><span class="client-sep">/</span>
                    <span class="client-item">爽</span><span class="client-sep">/</span>
                    <span class="client-item">田高健太郎</span><span class="client-sep">/</span>
                    <span class="client-item">ハルノ雨</span><span class="client-sep">/</span>
                    <span class="client-item">水原ゆき</span><span class="client-sep">/</span>
                    <span class="client-item">みゆう</span><span class="client-sep">/</span>
                    <span class="client-item">森大翔</span><span class="client-sep">/</span>
                    <span class="client-item">山下まみ</span><span class="client-sep">/</span>
                    <span class="client-item">吉岡茉祐</span><span class="client-sep">/</span>
                    <span class="client-item">脇田唯</span>
                </div>
            </div>

            <div class="list-group">
                <h3 class="list-header" style="background: var(--pop-5); box-shadow: 5px 5px 0 var(--c-text); color: var(--c-text);">CLIENTS</h3>
                <div class="client-list">
                    <span class="client-item">&Border</span><span class="client-sep">/</span>
                    <span class="client-item">AKTIO</span><span class="client-sep">/</span>
                    <span class="client-item">AMUSE INC.</span><span class="client-sep">/</span>
                    <span class="client-item">avex</span><span class="client-sep">/</span>
                    <span class="client-item">HOKKAIDO CONSADOLE SAPPORO</span><span class="client-sep">/</span>
                    <span class="client-item">K'sSOUND</span><span class="client-sep">/</span>
                    <span class="client-item">LeTAO</span><span class="client-sep">/</span>
                    <span class="client-item">TBS</span><span class="client-sep">/</span>

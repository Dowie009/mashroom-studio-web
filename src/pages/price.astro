---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="料金プラン｜札幌レコーディングスタジオ | MASHROOM STUDIO"
  description="MASHROOM STUDIO の料金プラン。エンジニア付きREC ¥4,500/h〜、6hパック ¥24,000、学生 ¥3,000/h。ミックス・マスタリング・MV制作も対応。札幌市北区のレコーディングスタジオ。"
>
    <script slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/Draggable.min.js" is:inline></script>

    <header class="nav-header">
        <a href="/" class="logo-container magnet">
            <img src="/img/logo.png" alt="MASHROOM STUDIO" class="logo-img">
            <img src="/img/logo.png" alt="" class="logo-glitch logo-glitch-1">
            <img src="/img/logo.png" alt="" class="logo-glitch logo-glitch-2">
        </a>
        <a href="/" class="back-btn magnet">← BACK TO HOME</a>
    </header>

    <!-- PAGE TITLE HEADER -->
    <div class="page-header">
        <h1 class="page-title reveal-text">PRICE LIST</h1>
        <p class="page-subtitle reveal-text">RECORDING STUDIO PRICE — SAPPORO</p>
    </div>

    <!-- TOGGLE SWITCH -->
    <div class="toggle-container reveal-text">
        <span class="toggle-label active" id="label-hourly">1h RATE</span>
        <div class="toggle-switch magnet" id="billing-toggle">
            <div class="toggle-knob"></div>
        </div>
        <span class="toggle-label" id="label-pack">6h PACK (お得!)</span>
    </div>

    <div class="swipe-hint" id="swipe-hint">&lt;&lt;&lt; DRAG TO SPIN &gt;&gt;&gt;<br><span style="font-size:0.8em; opacity:0.8;">TAP CARD FOR DETAILS</span></div>

    <!-- 3D CYLINDER CAROUSEL -->
    <div class="carousel-scene" id="carousel-scene">
        <div class="carousel-container" id="carousel-container">
            <!-- カードはJSで生成されます -->
        </div>
        <!-- NAVIGATION BUTTONS -->
        <div class="nav-btn nav-prev magnet" id="nav-prev">&lt;</div>
        <div class="nav-btn nav-next magnet" id="nav-next">&gt;</div>
        <!-- DICE BUTTON -->
        <div class="dice-btn magnet" id="dice-btn">
            <div class="dice-dot"></div><div class="dice-dot"></div><div class="dice-dot"></div><div class="dice-dot"></div><div class="dice-dot"></div>
        </div>
    </div>

    <!-- MODAL (CARD EXPANSION) -->
    <div class="modal-overlay" id="modal-overlay">
        <div class="modal-content" id="modal-content">
            <div class="modal-close" id="modal-close">×</div>
            <div class="modal-col-left" id="modal-col-left"></div>
            <div class="modal-col-right" id="modal-col-right"></div>
            <div id="modal-footer-action" style="grid-column: 1 / -1; text-align:center; width:100%;">
                <a href="/#contact" class="btn-pop magnet" style="width:100%; display:block; background:var(--c-text); color:white; font-size:1.5rem; padding:20px 0; border-radius: 12px;">相談する・予約する</a>
            </div>
        </div>
    </div>

    <!-- ADD-ON (STICKER WALL) -->
    <section class="addons-section">
        <!-- Free Ticker -->
        <div class="ticker-wrap">
            <div class="ticker">
                <div class="ticker-item">FREE: Wi-Fi <span>完備</span></div>
                <div class="ticker-item">FREE: PARKING <span>2台</span></div>
                <div class="ticker-item">FREE: COFFEE <span>エスプレッソ</span></div>
                <div class="ticker-item">FREE: 1st MIC <span>マイク1本</span></div>
                <div class="ticker-item">FREE: SETUP <span>セッティング</span></div>
                <div class="ticker-item">FREE: ADVICE <span>機材相談</span></div>
                <div class="ticker-item">FREE: STORAGE <span>データ1ヶ月</span></div>
                <div class="ticker-item">FREE: CHARGE <span>充電器</span></div>
                <!-- Duplicate for seamless loop -->
                <div class="ticker-item">FREE: Wi-Fi <span>完備</span></div>
                <div class="ticker-item">FREE: PARKING <span>2台</span></div>
                <div class="ticker-item">FREE: COFFEE <span>エスプレッソ</span></div>
                <div class="ticker-item">FREE: 1st MIC <span>マイク1本</span></div>
                <div class="ticker-item">FREE: SETUP <span>セッティング</span></div>
                <div class="ticker-item">FREE: ADVICE <span>機材相談</span></div>
                <div class="ticker-item">FREE: STORAGE <span>データ1ヶ月</span></div>
                <div class="ticker-item">FREE: CHARGE <span>充電器</span></div>
            </div>
        </div>

        <div class="addons-header">
            <h2 class="addons-title reveal-text">EXTRAS & FREEBIES</h2>
            <div class="addons-sub reveal-text">オプション・レンタル・キャンセル規定</div>
        </div>

        <div class="sticker-wall reveal-text" id="sticker-wall">
            <!-- Stickers rendered via JS -->
        </div>
    </section>

    <!-- NAVIGATION HUB -->
    <section style="background: var(--c-bg); padding: 50px 5% 60px; position: relative; z-index: 10; border-top: 5px solid var(--c-text); border-bottom: 5px solid var(--c-text);">
        <div style="max-width: 1400px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; gap: 30px; flex-wrap: wrap;">
            <h2 style="font-family: var(--font-en); font-size: 2.5rem; color: var(--c-text); margin: 0; letter-spacing: 0.1em;">05. PRICE LIST</h2>
            <div style="display: flex; justify-content: center; align-items: center; gap: 20px; flex-wrap: wrap;">
                <a href="/" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">00. HOME</a>
                <a href="/profile" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">01. PROFILE</a>
                <a href="/works" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">02. WORKS</a>
                <a href="/lesson" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">03. LESSON</a>
                <a href="/gear" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">04. GEAR</a>
                <a href="/price" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white); opacity: 0.5; pointer-events: none;">05. PRICE</a>
                <a href="https://blog.xn--3-sj5c.jp/" class="hub-link magnet" target="_blank" rel="noopener noreferrer" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">06. BLOG</a>
                <a href="/#contact" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">07. CONTACT</a>
            </div>
        </div>
    </section>

    <!-- FOOTER -->
    <footer>
        <p>&copy; 2025 MASHROOM STUDIO by Walewalewa</p>
    </footer>
</Layout>

<style is:global>
    /* CURSOR（ページ固有） */
    .cursor.on-modal {
        mix-blend-mode: normal;
        background: var(--pop-1);
        box-shadow: 0 0 20px var(--pop-1);
        border: 2px solid white;
        width: 30px; height: 30px;
        z-index: 999999 !important;
        pointer-events: none;
    }
    .cursor.on-modal.hovered { width: 60px; height: 60px; opacity: 0.8; }

    /* COMMON */
    h1, h2, h3 { text-transform: uppercase; line-height: 0.9; }
    .en-font { font-family: var(--font-en); }
    .btn-pop { display: inline-block; padding: 15px 40px; font-size: 1.2rem; font-weight: 900; color: var(--c-text); background: var(--c-white); border: 4px solid var(--c-text); text-decoration: none; box-shadow: 8px 8px 0px var(--c-text); transition: all 0.2s; position: relative; overflow: hidden; font-family: var(--font-en); border-radius: 12px; }
    .btn-pop:hover { transform: translate(-3px, -3px); box-shadow: 12px 12px 0px var(--c-text); background: var(--pop-2); }
    
    /* NAV HEADER (Works style) */
    .nav-header {
        padding: 10px 3%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--c-white);
        border-bottom: 4px solid var(--c-text);
        position: relative;
        z-index: 100;
        height: 150px;
    }
    .logo-container {
        display: block;
        text-decoration: none;
        position: relative;
        width: auto;
        height: 120px;
    }
    .logo-img {
        height: 100%;
        width: auto;
        display: block;
    }
    .logo-glitch {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        width: auto;
        opacity: 0;
        pointer-events: none;
    }
    .logo-container:hover .logo-glitch-1 {
        animation: glitch1 0.3s infinite;
    }
    .logo-container:hover .logo-glitch-2 {
        animation: glitch2 0.3s infinite;
    }
    @keyframes glitch1 {
        0%, 100% { opacity: 0; transform: translate(0); }
        20% { opacity: 0.8; transform: translate(-5px, 2px); filter: hue-rotate(90deg); }
        40% { opacity: 0; transform: translate(0); }
        60% { opacity: 0.6; transform: translate(3px, -2px); filter: hue-rotate(180deg); }
        80% { opacity: 0; transform: translate(0); }
    }
    @keyframes glitch2 {
        0%, 100% { opacity: 0; transform: translate(0); }
        25% { opacity: 0.7; transform: translate(4px, -3px); filter: hue-rotate(-90deg); }
        50% { opacity: 0; transform: translate(0); }
        75% { opacity: 0.5; transform: translate(-3px, 3px); filter: hue-rotate(270deg); }
    }
    .back-btn {
        font-family: var(--font-en);
        font-weight: bold;
        text-decoration: none;
        color: var(--c-text);
        border: 2px solid var(--c-text);
        padding: 10px 20px;
        transition: 0.3s;
        margin-right: 100px;
    }
    .back-btn:hover {
        background: var(--c-text);
        color: var(--c-white);
    }

    /* PAGE HEADER */
    .page-header { padding: 120px 5% 60px; background: var(--c-text); color: var(--pop-2); text-align: center; clip-path: polygon(0 0, 100% 0, 100% 90%, 0 100%); }
    .page-title { font-size: 8rem; font-family: var(--font-en); line-height: 0.8; margin-bottom: 20px; }
    .page-subtitle { font-size: 1.5rem; font-weight: 700; color: var(--c-white); font-family: var(--font-jp); }

    /* PRICING TOGGLE */
    .toggle-container { display: flex; justify-content: center; align-items: center; margin: 60px 0; gap: 20px; position: relative; z-index: 50; }
    .toggle-label { font-size: 1.5rem; font-weight: 900; font-family: var(--font-en); color: var(--c-text); opacity: 0.5; transition: 0.3s; }
    .toggle-label.active { opacity: 1; color: var(--pop-1); text-decoration: underline; text-decoration-thickness: 4px; }
    
    .toggle-switch { 
        width: 80px; height: 40px; background: var(--c-text); border-radius: 40px; position: relative; cursor: none; 
        border: 3px solid var(--c-text);
    }
    .toggle-knob { 
        width: 30px; height: 30px; background: var(--pop-2); border-radius: 50%; position: absolute; top: 2px; left: 2px; transition: 0.3s cubic-bezier(0.68, -0.55, 0.27, 1.55); 
        border: 2px solid var(--c-text);
    }
    .toggle-switch.on .toggle-knob { transform: translateX(40px); background: var(--pop-1); }

    /* 3D CAROUSEL */
    .carousel-scene {
        width: 100%;
        height: 520px; 
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        perspective: 1800px; 
        overflow: hidden;
        margin-bottom: 0; 
        padding-top: 40px;
        padding-bottom: 40px;
        background-color: #111; 
        border-top: 5px solid var(--c-text);
    }

    .carousel-scene::before {
        content: ''; position: absolute; top: 0; left: 0; width: 200%; height: 200%;
        background-image: linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
        background-size: 50px 50px;
        transform: perspective(500px) rotateX(60deg) translateY(-100px) translateZ(-200px);
        pointer-events: none;
    }

    .carousel-container {
        width: 190px; 
        height: 290px; 
        position: absolute;
        transform-style: preserve-3d;
    }

    /* NAVIGATION BUTTONS */
    .nav-btn {
        position: absolute; top: 50%; transform: translateY(-50%);
        width: 60px; height: 60px; background: var(--c-text); color: var(--pop-2);
        border: 3px solid var(--pop-2); border-radius: 50%;
        display: flex; justify-content: center; align-items: center;
        font-size: 2rem; font-weight: 900; font-family: var(--font-en);
        cursor: pointer; z-index: 100; transition: 0.2s;
        box-shadow: 5px 5px 0px rgba(0,0,0,0.3);
    }
    .nav-btn:hover { background: var(--pop-2); color: var(--c-text); border-color: var(--c-text); }
    .nav-prev { left: 30px; }
    .nav-next { right: 30px; }

    /* DICE BUTTON (CSSで作るリアルなサイコロ) */
    .dice-btn {
        position: absolute; bottom: 30px; right: 30px;
        width: 80px; height: 80px; background: var(--c-white);
        border: 4px solid var(--c-text); border-radius: 16px;
        cursor: pointer; z-index: 100; transition: 0.3s;
        box-shadow: 8px 8px 0px var(--pop-6); /* 黄色の影 */
        display: grid; grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(3, 1fr);
        padding: 10px; gap: 2px;
    }
    .dice-btn:hover { transform: translate(-3px, -3px) rotate(15deg); box-shadow: 12px 12px 0px var(--pop-6); }
    .dice-dot { background: var(--c-text); border-radius: 50%; width: 100%; height: 100%; }
    /* 5の目を作る */
    .dice-dot:nth-child(1) { grid-column: 1; grid-row: 1; }
    .dice-dot:nth-child(2) { grid-column: 3; grid-row: 1; }
    .dice-dot:nth-child(3) { grid-column: 2; grid-row: 2; }
    .dice-dot:nth-child(4) { grid-column: 1; grid-row: 3; }
    .dice-dot:nth-child(5) { grid-column: 3; grid-row: 3; }


    /* カード本体 */
    .plan-card { 
        position: absolute;
        width: 190px; 
        height: 290px; 
        left: 0;
        top: 0;
        background: var(--c-white); 
        border: 3px solid var(--c-text); 
        padding: 10px; 
        display: flex; flex-direction: column; 
        transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
        box-shadow: 4px 4px 0px rgba(0,0,0,0.1); 
        user-select: none;
        backface-visibility: hidden; 
        cursor: pointer; 
        border-radius: 12px; 
    }

    .plan-card::after {
        content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.8); opacity: 0; transition: opacity 0.3s; pointer-events: none;
        border-radius: 10px;
    }
    .plan-card.is-far::after { opacity: 0.7; }
    
    .plan-card.is-active { 
        z-index: 100;
    }
    /* アクティブ時のテキストカラーを黒に */
    .plan-card.is-active .plan-number,
    .plan-card.is-active .plan-features li span { color: var(--c-text) !important; }

    .badge { 
        position: absolute; top: -8px; right: -5px; 
        color: var(--c-text); padding: 2px 6px; font-weight: 900; font-family: var(--font-en); 
        border: 2px solid var(--c-text); transform: rotate(3deg); z-index: 20; font-size: 0.6rem;
        background: var(--c-white); 
        border-radius: 4px;
    }

    .plan-number { font-family: var(--font-digi); font-size: 0.7rem; color: #888; margin-bottom: 2px; transition: color 0.3s; }
    .plan-name { font-size: 1.2rem; font-family: var(--font-en); line-height: 0.9; margin-bottom: 5px; text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    
    .plan-desc { 
        display: block; 
        font-size: 0.55rem; 
        margin-bottom: 5px; 
        line-height: 1.3; 
        font-weight: 600; 
        height: 22px; 
        overflow: hidden; 
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }
    
    .plan-price-box { 
        background: var(--c-text); color: var(--c-white); padding: 3px; text-align: center; margin-bottom: 5px; 
        transform: rotate(-1deg); border: 2px solid var(--c-text); transition: 0.3s; 
        border-radius: 4px;
    }
    .plan-price { font-size: 1.1rem; font-family: var(--font-en); color: var(--pop-2); line-height: 1; }
    .plan-unit { font-size: 0.5rem; font-family: var(--font-jp); opacity: 0.8; }

    .plan-features { 
        list-style: none; margin-bottom: 5px; flex-grow: 1; overflow: hidden; 
        max-height: 50px;
    }
    .plan-features li { padding: 1px 0; border-bottom: 1px dashed #ddd; font-weight: 700; font-size: 0.55rem; display: flex; align-items: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .plan-features li span { transition: color 0.3s; }
    
    .plan-btn { width: 100%; text-align: center; background: var(--c-text); color: var(--c-white); padding: 4px 0; font-size: 0.7rem; border: 2px solid var(--c-text); pointer-events: none; margin-top: auto; border-radius: 6px; }
    
    /* SWIPE HINT (視認性アップ) */
    .swipe-hint { 
        text-align: center; font-family: var(--font-en); font-size: 1.2rem; 
        margin-top: -20px; margin-bottom: 30px; color: var(--c-white);
        background: rgba(0,0,0,0.6); border: 2px solid var(--pop-5); border-radius: 30px;
        display: inline-block; padding: 10px 30px;
        position: relative; left: 50%; transform: translateX(-50%);
        animation: blink 2s infinite; pointer-events: none; 
        box-shadow: 0 0 15px var(--pop-5);
    }
    @keyframes blink { 0%, 100% { opacity: 0.6; box-shadow: 0 0 15px var(--pop-5); } 50% { opacity: 1; box-shadow: 0 0 25px var(--pop-5); } }

    /* MODAL (拡大表示用) */
    .modal-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.85); z-index: 99999;
        display: none; justify-content: center; align-items: center;
        opacity: 0; backdrop-filter: blur(8px);
    }
    .modal-content {
        width: 90vw; max-width: 800px; height: auto; max-height: 90vh; 
        background: var(--c-white); border: 6px solid var(--c-text); padding: 50px;
        box-shadow: 0 0 50px rgba(0,0,0,0.5); 
        position: relative; transform: scale(0.8);
        display: grid; grid-template-columns: 1fr 1fr; gap: 40px; 
        align-items: center; overflow-y: auto; border-radius: 20px;
    }
    .modal-content .plan-number { font-size: 1.5rem; margin-bottom: 10px; }
    .modal-content .plan-name { font-size: 4rem; margin-bottom: 20px; white-space: normal; line-height: 0.9; }
    .modal-content .plan-desc { font-size: 1.2rem; -webkit-line-clamp: unset; height: auto; margin-bottom: 30px; }
    .modal-content .plan-price-box { padding: 20px; margin-bottom: 30px; transform: rotate(-2deg) scale(1.1); border-radius: 8px; }
    .modal-content .plan-price { font-size: 4rem; }
    .modal-content .plan-unit { font-size: 1.2rem; }
    .modal-content .plan-features { max-height: none; margin-bottom: 30px; }
    .modal-content .plan-features li { padding: 15px 0; font-size: 1.1rem; border-bottom: 2px dashed #ddd; }
    .modal-content .plan-btn { display: none; } 
    .modal-col-left { display: flex; flex-direction: column; justify-content: center; }
    .modal-col-right { display: flex; flex-direction: column; justify-content: center; }
    .modal-close {
        position: absolute; top: 20px; right: 20px;
        width: 60px; height: 60px; background: var(--c-text); color: white;
        border-radius: 50%; display: flex; justify-content: center; align-items: center;
        font-size: 2rem; cursor: pointer; border: 2px solid white; transition: 0.2s; z-index: 10;
    }
    .modal-close:hover { transform: rotate(90deg); background: var(--pop-1); }

    /* ADD-ON SECTION (STICKER WALL) */
    .addons-section {
        padding: 80px 0 140px;
        background: var(--pop-5); 
        border-top: 5px solid var(--c-text); 
        border-bottom: 5px solid var(--c-text); 
        position: relative; 
        z-index: 10; 
        overflow: hidden;
    }
    .addons-header { text-align: center; margin-bottom: 60px; position: relative; z-index: 2; margin-top: 100px; }
    .addons-title { font-size: 4rem; font-family: var(--font-en); text-shadow: 4px 4px 0px var(--c-white); line-height: 1; }
    .addons-sub { font-size: 1.2rem; font-weight: bold; margin-top: 10px; background: var(--c-text); color: var(--c-white); display: inline-block; padding: 5px 20px; transform: rotate(-2deg); }

    /* Ticker for Free Items */
    .ticker-wrap {
        position: absolute; top: 80px; left: 0; width: 100%; overflow: hidden; background: var(--pop-6); border-top: 4px solid var(--c-text); border-bottom: 4px solid var(--c-text); transform: rotate(2deg) scale(1.1); z-index: 1; box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    }
    .ticker {
        display: flex; width: max-content; animation: ticker 30s linear infinite; 
    }
    .ticker-item {

                modalRight.innerHTML = `
                    <p style="font-size:1.2rem; line-height:1.6; font-weight:bold;">${sticker.desc}</p>
                    <p style="font-size:0.9rem; margin-top:20px; opacity:0.7;">※ 詳細はご相談ください。</p>
                `;
                
                modalContent.style.borderColor = "var(--c-text)";
                modalContent.style.boxShadow = "0 0 50px rgba(0,0,0,0.2)";
                
                modalOverlay.style.display = 'flex';
                if (cursor) cursor.classList.add('on-modal');
                gsap.to(modalOverlay, { opacity: 1, duration: 0.3 });
                gsap.fromTo(modalContent, { scale: 0.8, opacity:0 }, { scale: 1, opacity:1, duration: 0.4, ease: "back.out(1.2)" });
            });
            stickerWall.appendChild(el);
        });


        // --- ROTATION LOGIC ---
        let currentRotation = 0;
        const proxy = document.createElement("div"); 

        function updateCarousel() {
            gsap.set(container, {
                rotationY: currentRotation
            });
            
            let normRot = -currentRotation % 360;
            if (normRot < 0) normRot += 360;
            
            const cards = document.querySelectorAll('.plan-card');
            cards.forEach((card, i) => {
                const cardAngle = (theta * i) % 360;
                let diff = Math.abs(cardAngle - normRot);
                if (diff > 180) diff = 360 - diff;
                
                const color = popColors[i % popColors.length];
                const shadowColor = popColors[(i + 2) % popColors.length];
                const priceBox = document.getElementById(`box-${i}`);

                if (diff < theta / 1.2) { // アクティブ判定
                    card.classList.add('is-active');
                    card.classList.remove('is-far');
                    // アクティブ時のスタイル (影の色を変更)
                    card.style.borderColor = color;
                    card.style.boxShadow = `4px 4px 0px ${shadowColor}`; 
                    card.style.transform = `rotateY(${theta * i}deg) translateZ(${radius}px) scale(1.1)`;
                    card.style.pointerEvents = "auto"; 
                    
                    if (priceBox) {
                        priceBox.style.background = color;
                        priceBox.style.color = "black";
                        priceBox.querySelectorAll('.plan-price').forEach(p => p.style.color = "black");
                    }
                    
                } else {
                    card.classList.remove('is-active');
                    if (diff > 100) card.classList.add('is-far');
                    else card.classList.remove('is-far');
                    
                    // 非アクティブ時のスタイル
                    card.style.borderColor = "#333"; 
                    card.style.boxShadow = `none`;
                    card.style.transform = `rotateY(${theta * i}deg) translateZ(${radius}px) scale(1)`;
                    card.style.pointerEvents = "none"; 
                    
                    if (priceBox) {
                        priceBox.style.background = "var(--c-text)";
                        priceBox.style.color = "#888";
                        priceBox.querySelectorAll('.plan-price').forEach(p => p.style.color = "#aaa");
                    }
                }
            });
        }

        Draggable.create(proxy, {
            trigger: "#carousel-scene",
            type: "x",
            inertia: true,
            edgeResistance: 0.9, 
            dragResistance: 0.4, 
            onDrag: function() {
                const rotateSpeed = 0.15;
                currentRotation += this.deltaX * rotateSpeed;
                updateCarousel();
            },
            onThrowUpdate: function() {
                const rotateSpeed = 0.15;
                currentRotation += this.deltaX * rotateSpeed;
                updateCarousel();
            },
            onClick: function(e) {}
        });

        // Navigation Buttons - Click Action
        const rotateCarousel = (deltaAngle, duration = 0.5, ease = "power2.out") => {
            const targetRotation = currentRotation + deltaAngle;
            gsap.to({ val: currentRotation }, {
                val: targetRotation,
                duration: duration,
                ease: ease,
                onUpdate: function() {
                    currentRotation = this.targets()[0].val;
                    updateCarousel();
                }
            });
        };
        
        const navPrev = document.getElementById('nav-prev');
        const navNext = document.getElementById('nav-next');
        if (navPrev) navPrev.addEventListener('click', () => rotateCarousel(theta));
        if (navNext) navNext.addEventListener('click', () => rotateCarousel(-theta));

        // Dice Button (Random Spin)
        const diceBtn = document.getElementById('dice-btn');
        if (diceBtn) {
            diceBtn.addEventListener('click', () => {
                const randomIndex = Math.floor(Math.random() * numCards);
                
                // Adjust for current rotation cycles
                const currentCycle = Math.floor(currentRotation / 360);
                let target = (currentCycle * 360) - (theta * randomIndex);
                
                // Ensure we spin at least 2 times
                if (target > currentRotation - 720) {
                    target -= 1080;
                }
                
                gsap.to({ val: currentRotation }, {
                    val: target,
                    duration: 3, 
                    ease: "power4.inOut", 
                    onUpdate: function() { 
                        currentRotation = this.targets()[0].val; 
                        updateCarousel(); 
                    }
                });
            });
        }

        updateCarousel(); // 初期実行

        // --- EXPAND CARD LOGIC ---
        let isPack = false;

        document.querySelectorAll('.plan-card').forEach(card => {
            card.addEventListener('click', () => {
                if(!card.classList.contains('is-active')) return; 

                const i = card.getAttribute('data-index');
                const data = plansData[i];
                const color = popColors[i % popColors.length];
                const shadowColor = popColors[(i + 2) % popColors.length];
                
                const num = (parseInt(i) + 1).toString().padStart(2, '0');
                
                if (!modalLeft || !modalRight || !modalContent || !modalOverlay) return;

                modalLeft.innerHTML = `
                    <div class="plan-number" style="color:${color};">PLAN.${num}</div>
                    <div class="plan-name">${data.name}</div>
                    <div class="plan-desc">${data.desc}</div>
                    <div class="plan-price-box" style="background:${color}; color:black; border-color:black;">
                        <div class="plan-price price-hourly ${isPack ? 'hidden' : ''}">¥${data.priceH}</div>
                        <div class="plan-price price-pack ${isPack ? '' : 'hidden'}">¥${data.priceP}</div>
                        <div class="plan-unit unit-hourly ${isPack ? 'hidden' : ''}">/ ${data.unitH || '1h'}</div>
                        <div class="plan-unit unit-pack ${isPack ? '' : 'hidden'}">/ ${data.unitP || '6h PACK'}</div>
                    </div>
                `;
                
                const fullFeatures = data.features.map(f => `<li style="border-bottom-color:${color}88;"><span style="color:${color}; margin-right:10px;">★</span>${f}</li>`).join('');
                modalRight.innerHTML = `
                    <ul class="plan-features">${fullFeatures}</ul>
                `;

                modalContent.style.borderColor = color;
                modalContent.style.boxShadow = `10px 10px 0px ${shadowColor}`; 

                modalOverlay.style.display = 'flex';
                if (cursor) cursor.classList.add('on-modal'); 
                
                gsap.to(modalOverlay, { opacity: 1, duration: 0.3 });
                gsap.fromTo(modalContent, { scale: 0.8, opacity:0 }, { scale: 1.1, opacity:1, duration: 0.5, ease: "back.out(1.2)" });
            });
        });

        const closeModal = () => {
            if (!modalOverlay) return;
            gsap.to(modalOverlay, { opacity: 0, duration: 0.3, onComplete: () => { 
                modalOverlay.style.display = 'none'; 
                if (cursor) cursor.classList.remove('on-modal');
            }});
        };
        if (modalClose) modalClose.addEventListener('click', closeModal);
        if (modalOverlay) modalOverlay.addEventListener('click', (e) => { if(e.target === modalOverlay) closeModal(); });


        // --- TOGGLE LOGIC ---
        const toggleSwitch = document.getElementById('billing-toggle');
        const labelHourly = document.getElementById('label-hourly');
        const labelPack = document.getElementById('label-pack');

        if (toggleSwitch) {
            toggleSwitch.addEventListener('click', () => {
                isPack = !isPack;
                toggleSwitch.classList.toggle('on');
                
                const updatePrices = (parent) => {
                    if (isPack) {
                        parent.querySelectorAll('.price-hourly, .unit-hourly').forEach(el => el.classList.add('hidden'));
                        parent.querySelectorAll('.price-pack, .unit-pack').forEach(el => el.classList.remove('hidden'));
                        gsap.fromTo(parent.querySelectorAll('.price-pack'), {scale: 0.5, opacity: 0}, {scale: 1, opacity: 1, duration: 0.4, ease: 'back.out(1.7)'});
                    } else {
                        parent.querySelectorAll('.price-pack, .unit-pack').forEach(el => el.classList.add('hidden'));
                        parent.querySelectorAll('.price-hourly, .unit-hourly').forEach(el => el.classList.remove('hidden'));
                        gsap.fromTo(parent.querySelectorAll('.price-hourly'), {scale: 0.5, opacity: 0}, {scale: 1, opacity: 1, duration: 0.4, ease: 'back.out(1.7)'});
                    }
                };

                if(isPack) {
                    if (labelHourly) labelHourly.classList.remove('active');
                    if (labelPack) labelPack.classList.add('active');
                } else {
                    if (labelPack) labelPack.classList.remove('active');
                    if (labelHourly) labelHourly.classList.add('active');
                }

                document.querySelectorAll('.plan-card').forEach(card => updatePrices(card));
                
                if(modalOverlay && modalOverlay.style.display === 'flex') {
                    const modalPriceBox = document.querySelector('.modal-content .plan-price-box');
                    if(modalPriceBox) updatePrices(modalPriceBox);
                }
            });
        }

        gsap.utils.toArray('.reveal-text').forEach(element => {
            gsap.fromTo(element, { y: 50, opacity: 0 }, { y: 0, opacity: 1, duration: 0.8, ease: 'power4.out', scrollTrigger: { trigger: element, start: 'top 85%' } });
        });
    }
</script>

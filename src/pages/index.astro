    <script>
        gsap.registerPlugin(ScrollTrigger);
        // パーティクル生成
        const particlesContainer = document.getElementById('particles');
        if (particlesContainer) {
            for (let i = 0; i < 10; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.width = (Math.random() * 6 + 4) + 'px';
                particle.style.height = particle.style.width;
                particle.style.animationDelay = Math.random() * 10 + 's';
                particle.style.animationDuration = (Math.random() * 6 + 10) + 's';
                particlesContainer.appendChild(particle);
            }
        }

        const isMobile = window.innerWidth <= 900;

        if (!isMobile) {
            gsap.utils.toArray('.reveal-text').forEach(element => { 
                gsap.fromTo(element, { y: 100, opacity: 0 }, { y: 0, opacity: 1, duration: 1, ease: 'power4.out', scrollTrigger: { trigger: element, start: 'top 80%', toggleActions: 'play none none reverse' } }); 
            });
        } else {
            // Simple fade in for mobile to prevent "shaking"
            gsap.utils.toArray('.reveal-text').forEach(element => { 
                gsap.fromTo(element, { opacity: 0 }, { opacity: 1, duration: 0.5, scrollTrigger: { trigger: element, start: 'top 90%' } }); 
            });
        }
        
        const hubs = gsap.utils.toArray('.nav-hub-container');
        hubs.forEach(hub => {
            const links = hub.querySelectorAll('a');
            gsap.from(links, {
                x: -50,
                opacity: 0,
                duration: 0.8,
                ease: "back.out(1.7)",
                stagger: 0.1,
                scrollTrigger: {
                    trigger: hub,
                    start: "top 95%", 
                    toggleActions: "play none none reverse"
                }
            });
        });

        const marqueeContent = document.querySelector('.marquee-content');
        const clone = marqueeContent.cloneNode(true);
        document.querySelector('.gallery-wrapper').appendChild(clone);
        gsap.to('.marquee-content', { xPercent: -100, ease: "none", duration: 20, repeat: -1 });

        const searchInput = document.getElementById('qa-search');
        const qaItems = document.querySelectorAll('.qa-item');
        searchInput.addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            qaItems.forEach(item => { item.style.display = item.innerText.toLowerCase().includes(term) ? 'block' : 'none'; });
        });
        
        // Q&Aアコーディオンの切り替えロジック
        qaItems.forEach(item => { item.addEventListener('click', () => { 
            // PC版ではアコーディオン
            if (window.innerWidth > 900) {
                item.classList.toggle('active');
            }
        }); });

        // --- MISSIONS CARD CLICK LOGIC ---
        const cardItems = document.querySelectorAll('.card');
        cardItems.forEach(card => {
            card.addEventListener('click', () => {
                if (window.innerWidth > 900) return; // PCでは何もしない (ホバーアニメーションが優先)

                const details = card.querySelector('.card-details');
                const toggle = card.querySelector('.card-toggle');

                if (details && toggle) {
                    const isOpening = !card.classList.contains('is-open');

                    // 他のカードを閉じる
                    cardItems.forEach(otherCard => {
                        if (otherCard !== card && otherCard.classList.contains('is-open')) {
                            gsap.to(otherCard.querySelector('.card-details'), { height: 0, opacity: 0, duration: 0.2, onComplete: () => { otherCard.querySelector('.card-details').style.display = 'none'; } });
                            otherCard.querySelector('.card-toggle').innerText = '詳細を見る 🔽';
                            otherCard.classList.remove('is-open');
                        }
                    });

                    if (isOpening) {
                        // 開く
                        details.style.display = 'block';
                        gsap.fromTo(details, { height: 0, opacity: 0 }, { height: 'auto', opacity: 1, duration: 0.3, ease: 'power2.out' });
                        toggle.innerText = '閉じる 🔼';
                        card.classList.add('is-open');
                    } else {
                        // 閉じる
                        gsap.to(details, { height: 0, opacity: 0, duration: 0.2, onComplete: () => { details.style.display = 'none'; } });
                        toggle.innerText = '詳細を見る 🔽';
                        card.classList.remove('is-open');
                    }
                }
            });
        });

        // --- ESTIMATE AND OTHER LOGIC ---
        const estPlan = document.getElementById('est-plan');
        const estHours = document.getElementById('est-hours');
        const estOpt = document.getElementById('est-opt');
        const estTotal = document.getElementById('est-total');
        const copyBtn = document.getElementById('copy-line-btn');

        function calculateTotal() {
            const total = (parseInt(estPlan.value) * parseInt(estHours.value)) + parseInt(estOpt.value);
            estTotal.innerText = total.toLocaleString();
        }
        [estPlan, estHours, estOpt].forEach(el => el.addEventListener('change', calculateTotal));

        copyBtn.addEventListener('click', () => {
            const textToCopy = `【見積もり相談】\nプラン: ${estPlan.options[estPlan.selectedIndex].text}\n時間: ${estHours.options[estHours.selectedIndex].text}\nオプション: ${estOpt.options[estOpt.selectedIndex].text}\n概算合計: ¥${estTotal.innerText}\n\nこの内容で予約・相談したいです。`;
            const tempInput = document.createElement("textarea");
            tempInput.value = textToCopy;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand("copy");
            console.log('内容をコピーしました');
        });

        // ページロード時に合計を計算
        calculateTotal();

        // ===== DEBUG PANEL: .handwritten-msg 調整用 =====
        (function() {
            const target = document.querySelector('.handwritten-msg');
            if (!target) return;

            const panel = document.createElement('div');
            panel.id = 'debug-panel';
            panel.innerHTML = `
                <style>
                    #debug-panel {
                        position: fixed; top: 10px; left: 10px; z-index: 99999;
                        background: rgba(0,0,0,0.92); color: #0f0; font-family: monospace; font-size: 13px;
                        padding: 16px 20px; border-radius: 10px; border: 1px solid #0f0;
                        min-width: 320px; cursor: move; user-select: none;
                        backdrop-filter: blur(8px);
                    }
                    #debug-panel h3 { margin: 0 0 12px; color: #0f0; font-size: 14px; text-align: center; }
                    #debug-panel .row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
                    #debug-panel label { width: 110px; text-align: right; flex-shrink: 0; }
                    #debug-panel input[type=range] { flex: 1; accent-color: #0f0; }
                    #debug-panel .val { width: 70px; text-align: left; color: #fff; }
                    #debug-panel .actions { display: flex; gap: 8px; margin-top: 14px; }
                    #debug-panel button {
                        flex: 1; padding: 8px; border: 1px solid #0f0; background: transparent;
                        color: #0f0; font-family: monospace; font-size: 12px; cursor: pointer; border-radius: 4px;
                    }
                    #debug-panel button:hover { background: #0f0; color: #000; }
                    #debug-panel .copied { color: #ff0; font-size: 11px; text-align: center; margin-top: 6px; min-height: 16px; }
                </style>
                <h3>DEBUG: .handwritten-msg</h3>
                <div class="row"><label>rotate:</label><input type="range" id="dbg-rotate" min="-20" max="20" step="0.5" value="-3"><span class="val" id="dbg-rotate-v">-3deg</span></div>
                <div class="row"><label>scale:</label><input type="range" id="dbg-scale" min="0.3" max="2" step="0.05" value="1"><span class="val" id="dbg-scale-v">1</span></div>
                <div class="row"><label>margin-bottom:</label><input type="range" id="dbg-mb" min="-200" max="200" step="5" value="0"><span class="val" id="dbg-mb-v">0px</span></div>
                <div class="row"><label>margin-top:</label><input type="range" id="dbg-mt" min="-200" max="200" step="5" value="0"><span class="val" id="dbg-mt-v">0px</span></div>
                <div class="row"><label>width:</label><input type="range" id="dbg-w" min="30" max="150" step="1" value="100"><span class="val" id="dbg-w-v">100%</span></div>
                <div class="actions">
                    <button id="dbg-copy">COPY CSS</button>
                    <button id="dbg-reset">RESET</button>
                </div>
                <div class="copied" id="dbg-copied"></div>
            `;
            document.body.appendChild(panel);

            const els = {
                rotate: document.getElementById('dbg-rotate'),
                scale: document.getElementById('dbg-scale'),
                mb: document.getElementById('dbg-mb'),
                mt: document.getElementById('dbg-mt'),
                w: document.getElementById('dbg-w'),
            };
            const vals = {
                rotate: document.getElementById('dbg-rotate-v'),
                scale: document.getElementById('dbg-scale-v'),
                mb: document.getElementById('dbg-mb-v'),
                mt: document.getElementById('dbg-mt-v'),
                w: document.getElementById('dbg-w-v'),
            };

            function apply() {
                const r = els.rotate.value;
                const s = els.scale.value;
                const mb = els.mb.value;
                const mt = els.mt.value;
                const w = els.w.value;
                target.style.transform = 'rotate(' + r + 'deg) scale(' + s + ')';
                target.style.marginBottom = mb + 'px';
                target.style.marginTop = mt + 'px';
                target.style.width = w + '%';
                vals.rotate.textContent = r + 'deg';
                vals.scale.textContent = s;
                vals.mb.textContent = mb + 'px';
                vals.mt.textContent = mt + 'px';
                vals.w.textContent = w + '%';
            }

            Object.values(els).forEach(function(el) { el.addEventListener('input', apply); });

            document.getElementById('dbg-copy').addEventListener('click', function() {
                const css = '.handwritten-msg {\n'
                    + '  width: ' + els.w.value + '%;\n'
                    + '  transform: rotate(' + els.rotate.value + 'deg) scale(' + els.scale.value + ');\n'
                    + '  margin-top: ' + els.mt.value + 'px;\n'
                    + '  margin-bottom: ' + els.mb.value + 'px;\n'
                    + '}';
                navigator.clipboard.writeText(css);
                document.getElementById('dbg-copied').textContent = 'Copied!';
                setTimeout(function() { document.getElementById('dbg-copied').textContent = ''; }, 2000);
            });

            document.getElementById('dbg-reset').addEventListener('click', function() {
                els.rotate.value = -3; els.scale.value = 1; els.mb.value = 0; els.mt.value = 0; els.w.value = 100;
                apply();
            });

            // ドラッグ移動
            let dragging = false, dx = 0, dy = 0;
            panel.addEventListener('mousedown', function(e) {
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON') return;
                dragging = true; dx = e.clientX - panel.offsetLeft; dy = e.clientY - panel.offsetTop;
            });
            document.addEventListener('mousemove', function(e) {
                if (!dragging) return;
                panel.style.left = (e.clientX - dx) + 'px'; panel.style.top = (e.clientY - dy) + 'px';
            });
            document.addEventListener('mouseup', function() { dragging = false; });
        })();

        // ===== DEBUG: MISSIONS 上下の空白 調整パネル =====
        (function() {
            var menu = document.querySelector('.menu');
            if (!menu) return;

            var dynStyle = document.createElement('style');
            dynStyle.id = 'dbg-menu-gap-style';
            document.head.appendChild(dynStyle);

            var panel = document.createElement('div');
            panel.id = 'debug-panel-gap';
            panel.innerHTML = '<style>'
                + '#debug-panel-gap { position:fixed; bottom:10px; left:10px; z-index:99999; background:rgba(0,0,0,0.92); color:#0f0; font-family:monospace; font-size:13px; padding:16px 20px; border-radius:10px; border:1px solid #0f0; min-width:360px; cursor:move; user-select:none; backdrop-filter:blur(8px); }'
                + '#debug-panel-gap h3 { margin:0 0 10px; color:#0f0; font-size:14px; text-align:center; }'
                + '#debug-panel-gap .section-label { color:#ff0; font-size:12px; font-weight:bold; margin:12px 0 6px; padding-top:8px; border-top:1px solid rgba(0,255,0,0.3); }'
                + '#debug-panel-gap .section-label:first-of-type { border-top:none; margin-top:4px; }'
                + '#debug-panel-gap .row { display:flex; align-items:center; gap:8px; margin-bottom:6px; }'
                + '#debug-panel-gap label { width:100px; text-align:right; flex-shrink:0; font-size:12px; }'
                + '#debug-panel-gap input[type=range] { flex:1; accent-color:#0f0; }'
                + '#debug-panel-gap .val { width:60px; text-align:left; color:#fff; font-size:12px; }'
                + '#debug-panel-gap .actions { display:flex; gap:8px; margin-top:14px; }'
                + '#debug-panel-gap button { flex:1; padding:8px; border:1px solid #0f0; background:transparent; color:#0f0; font-family:monospace; font-size:12px; cursor:pointer; border-radius:4px; }'
                + '#debug-panel-gap button:hover { background:#0f0; color:#000; }'
                + '#debug-panel-gap .copied { color:#ff0; font-size:11px; text-align:center; margin-top:6px; min-height:16px; }'
                + '</style>'
                + '<h3>DEBUG: MISSIONS 上下の空白調整</h3>'
                + '<div class="section-label">▲ 上の空白（about → MISSIONS）</div>'
                + '<div class="row"><label>::before高さ:</label><input type="range" id="dbg-topH" min="0" max="300" step="1" value="60"><span class="val" id="dbg-topH-v">60px</span></div>'

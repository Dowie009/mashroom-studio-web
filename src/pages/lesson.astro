---
import Layout from '../layouts/Layout.astro';
---

<Layout title="LESSON & FLOW | MASHROOM STUDIO">
    <div class="bg-decor"></div>
    <div class="bg-grid"></div>

    <header>
        <a href="/" class="logo-container magnet">
            <img src="/img/logo.png" alt="MASHROOM STUDIO" class="logo-img">
            <img src="/img/logo.png" alt="" class="logo-glitch logo-glitch-1">
            <img src="/img/logo.png" alt="" class="logo-glitch logo-glitch-2">
        </a>
        <a href="/" class="back-btn magnet">← BACK TO HOME</a>
    </header>

    <section class="hero">
        <div class="hero-tag reveal-hero">ONLINE & STUDIO LESSON</div>
        <h1 class="hero-title">
            <span class="nowrap">あなたの音楽を、</span><br class="br-sp"><span class="nowrap">プロのクオリティで。</span>
        </h1>
        <p class="hero-desc reveal-hero">
            「わからない」を「できた！」に変える最短ルート。<br class="br-pc">
            初心者からプロ志向まで、<br class="br-sp">一人ひとりに合わせたマンツーマンレッスン。
        </p>
        <a href="#reserve" class="hero-btn magnet reveal-hero">無料相談を予約する</a>
    </section>

    <section class="flow-section">
        <h2 class="section-title reveal">LESSON FLOW</h2>
        
        <div class="flow-container">
            <div class="flow-card magnet reveal-card">
                <div class="step-num">01</div>
                <div class="step-illust">
                    <img src="/img/step1-counseling.png" alt="無料カウンセリング">
                </div>
                <h3 class="step-title">無料カウンセリング</h3>
                <p class="step-short">まずはあなたの<br>「やりたいこと」を<br>お聞かせください。</p>
                <div class="toggle-icon">CLICK FOR DETAIL</div>
                
                <div class="card-detail">
                    <ul class="flow-detail-list">
                        <li>
                            <span class="emoji">🗣</span>
                            <span class="txt"><strong>ヒアリング:</strong> あなたの「悩み」や「夢」をリラックスしてお話しましょう。</span>
                        </li>
                        <li>
                            <span class="emoji">🎸</span>
                            <span class="txt"><strong>機材相談:</strong> 「何を買えばいい？」から相談OK。</span>
                        </li>
                        <li>
                            <span class="emoji">💻</span>
                            <span class="txt"><strong>形式自由:</strong> Zoom / LINE / スタジオ対面、選べます。</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="flow-arrow reveal-card">▶</div>

            <div class="flow-card magnet reveal-card">
                <div class="step-num">02</div>
                <div class="step-illust">
                    <img src="/img/step2-planning.png" alt="プランのご提案">
                </div>
                <h3 class="step-title">プランのご提案</h3>
                <p class="step-short">あなただけの<br>「上達の地図」を<br>作ります。</p>
                <div class="toggle-icon">CLICK FOR DETAIL</div>

                 <div class="card-detail">
                    <ul class="flow-detail-list">
                        <li>
                            <span class="emoji">🗺</span>
                            <span class="txt"><strong>上達の地図:</strong> あなた専用のカリキュラムを作成。</span>
                        </li>
                        <li>
                            <span class="emoji">🎯</span>
                            <span class="txt"><strong>目標設定:</strong> 「3ヶ月で1曲」「予算5万円で」など具体的に。</span>
                        </li>
                        <li>
                            <span class="emoji">💰</span>
                            <span class="txt"><strong>明朗会計:</strong> 必要な費用を事前にご提示。無理な勧誘なし！</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="flow-arrow reveal-card">▶</div>

            <div class="flow-card magnet reveal-card">
                <div class="step-num">03</div>
                <div class="step-illust">
                    <img src="/img/step3-lesson.png" alt="レッスンスタート">
                </div>
                <h3 class="step-title">レッスンスタート</h3>
                <p class="step-short">いよいよ制作開始！<br>一緒に手を<br>動かしましょう。</p>
                <div class="toggle-icon">CLICK FOR DETAIL</div>

                 <div class="card-detail">
                    <ul class="flow-detail-list">
                        <li>
                            <span class="emoji">🔥</span>
                            <span class="txt"><strong>実践形式:</strong> 画面共有や実機操作で、「作りながら」学ぶ。</span>
                        </li>
                        <li>
                            <span class="emoji">🎵</span>
                            <span class="txt"><strong>あなた仕様:</strong> 教科書通りではなく、「作りたい曲」のための技術を。</span>
                        </li>
                        <li>
                            <span class="emoji">📹</span>
                            <span class="txt"><strong>復習OK:</strong> レッスン動画を録画して後で見返せます。</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="flow-arrow reveal-card">▶</div>

            <div class="flow-card magnet reveal-card">
                <div class="step-num">04</div>
                <div class="step-illust">
                    <img src="/img/step4-completion.png" alt="完成&フィードバック">
                </div>
                <h3 class="step-title">完成 & フィードバック</h3>
                <p class="step-short">作品の完成！<br>次のステップへ。</p>
                <div class="toggle-icon">CLICK FOR DETAIL</div>

                 <div class="card-detail">
                    <ul class="flow-detail-list">
                        <li>
                            <span class="emoji">✨</span>
                            <span class="txt"><strong>プロの視点:</strong> クオリティを上げるための最終アドバイス。</span>
                        </li>
                        <li>
                            <span class="emoji">🚀</span>
                            <span class="txt"><strong>発信サポート:</strong> SNS投稿や配信リリースの手順もレクチャー。</span>
                        </li>
                        <li>
                            <span class="emoji">🤝</span>
                            <span class="txt"><strong>次のステップ:</strong> 「できた！」を自信に、次の目標へ。</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="case-section">
        <div class="case-header">
            <h2 class="section-title reveal">CASE STUDY</h2>
            <p class="case-sub reveal">実際にどんな人が利用しているの？</p>
        </div>

        <div class="case-container">
            <div class="case-grid">
                <div class="case-card magnet reveal">
                    <div class="case-tag" style="background:var(--pop-1); color:white;">歌ってみた初心者</div>
                    <h3 class="case-title">初めての録音。<br>機材選びからMixまで。</h3>
                    <p class="case-digest">PCも持っていない状態からスタート。予算10万円で揃う機材の選定アドバイスから始め...</p>
                    <div class="case-footer">
                        <span>3ヶ月コース</span>
                        <span class="case-price">Click to Open</span>
                    </div>
                    <div class="card-detail">
                        <p style="margin-bottom:10px;">PCも持っていない状態からスタートしたAさん。予算10万円で揃う機材の選定アドバイスから始め、3ヶ月後には自分で動画投稿まで！</p>
                        <ul class="case-detail-list">
                            <li><span>01</span> カウンセリング：予算と目標の設定</li>
                            <li><span>02</span> 機材購入同行 & セットアップ講習</li>
                            <li><span>03</span> DAW（Studio One）の基本操作レッスン</li>
                            <li><span>04</span> 初レコーディング & 簡易ミックス指導</li>
                            <li><span>GOAL</span> 「歌ってみた」初投稿完了！</li>
                        </ul>
                        <div style="text-align:right; font-weight:bold; color:var(--pop-1); margin-top:10px;">¥60,000 (全6回)</div>
                    </div>
                </div>
                
                <div class="case-card magnet reveal" style="border-left-color: var(--pop-5);">
                    <div class="case-tag" style="background:var(--pop-5); color:black;">オリジナル曲制作</div>
                    <h3 class="case-title">鼻歌から<br>フルアレンジへ。</h3>
                    <p class="case-digest">メロディは浮かぶけどコードがわからない方。AI作曲支援ツールの使い方とコード進行の基礎をレッスン。</p>
                    <div class="case-footer">
                        <span>2ヶ月コース</span>
                        <span class="case-price">Click to Open</span>
                    </div>
                    <div class="card-detail">
                        <p style="margin-bottom:10px;">メロディは浮かぶけどコードがわからないBさん。AI作曲支援ツールの使い方と、コード進行の基礎をレッスン。</p>
                        <ul class="case-detail-list">
                            <li><span>01</span> 作りたい曲のイメージ共有</li>
                            <li><span>02</span> AIツール（Synthesizer V等）活用法</li>
                            <li><span>03</span> コード進行のパズル的理解</li>
                            <li><span>04</span> アレンジ構築 & 音色選び</li>
                            <li><span>GOAL</span> オリジナル曲のデモ完成！</li>
                        </ul>
                        <div style="text-align:right; font-weight:bold; color:var(--pop-5); margin-top:10px;">¥45,000 (全4回)</div>
                    </div>
                </div>

                <div class="case-card magnet reveal" style="border-left-color: var(--pop-2);">
                    <div class="case-tag" style="background:var(--pop-2); color:black;">バンドマン</div>
                    <h3 class="case-title">デモ音源の<br>クオリティアップ。</h3>
                    <p class="case-digest">バンドのデモ音源をよりプロフェッショナルに。ミックス・マスタリングの実践レッスン。</p>
                    <div class="case-footer">
                        <span>1.5ヶ月コース</span>
                        <span class="case-price">Click to Open</span>
                    </div>
                    <div class="card-detail">
                        <p style="margin-bottom:10px;">バンド活動をしているCさん。自分たちで録音したデモのクオリティを上げたい！</p>
                        <ul class="case-detail-list">
                            <li><span>01</span> 現状のデモ音源分析</li>
                            <li><span>02</span> ミックスの基礎理論レッスン</li>
                            <li><span>03</span> プラグインの実践的な使い方</li>
                            <li><span>04</span> マスタリングの基本</li>
                            <li><span>GOAL</span> 配信リリース可能なクオリティに！</li>
                        </ul>
                        <div style="text-align:right; font-weight:bold; color:var(--pop-2); margin-top:10px;">¥35,000 (全3回)</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="faq-section" id="faq">
        <h2 class="section-title reveal">FAQ</h2>
        <div class="faq-container">
            <div class="faq-item reveal">
                <div class="faq-q">Q. 完全初心者でも大丈夫ですか？</div>
                <div class="faq-a">A. もちろんです！機材の選び方から丁寧にサポートします。「何もわからない」状態からのスタートでも全く問題ありません。</div>
            </div>
            <div class="faq-item reveal">
                <div class="faq-q">Q. オンラインレッスンはどのように行いますか？</div>
                <div class="faq-a">A. ZoomやDiscordなどのビデオ通話ツールを使用します。画面共有で実際の作業を見せながら進めるので、対面レッスンとほぼ同じ感覚で学べます。</div>
            </div>
            <div class="faq-item reveal">
                <div class="faq-q">Q. レッスン料金の支払い方法は？</div>
                <div class="faq-a">A. 銀行振込、クレジットカード決済、PayPayなど各種決済に対応しています。詳しくはカウンセリング時にご案内します。</div>
            </div>
            <div class="faq-item reveal">
                <div class="faq-q">Q. キャンセルや日程変更は可能ですか？</div>
                <div class="faq-a">A. レッスン開始24時間前までのご連絡であれば、日程変更が可能です。それ以降のキャンセルは1回分消化となりますのでご注意ください。</div>
            </div>
        </div>
    </section>

    <section class="reserve-section" id="reserve">
        <!-- 上部 2カラム -->
        <div class="reserve-top">
            <!-- 左カラム -->
            <div class="reserve-info">
                <h2 class="section-title reveal" style="font-size:3.5rem; line-height:1;">無料相談予約</h2>
                <div class="safe-badge reveal-hero">
                    <span class="safe-icon">🔒</span>
                    <span>完全無料・勧誘なし</span>
                </div>
                <div class="safe-badge reveal-hero">
                    <span class="safe-icon">⏱</span>
                    <span>所要時間：約30分</span>
                </div>
                <div class="safe-badge reveal-hero">
                    <span class="safe-icon">💬</span>
                    <span>オンライン / 対面 選択可</span>
                </div>
                <p class="reserve-desc">
                    まずは気軽にお話ししましょう。<br>
                    あなたの「やりたいこと」を聞かせてください。<br>
                    <strong style="color:var(--pop-1);">強引な勧誘は一切ありません。</strong>
                </p>
                <div class="voice-box reveal">
                    <div class="voice-title">💭 こんな相談が届いています</div>
                    <div class="voice-item">「<em>仮歌のお仕事</em>を始めたい。機材を何から揃えればいいか分からない」</div>
                    <div class="voice-item">「ミュージシャンだけど<em>声優の仕事</em>を家でやってみたい。機材選びから教えてほしい」</div>
                    <div class="voice-item">「<em>レコーディング→納品→配信</em>までの流れを一通り知りたい」</div>
                    <div class="voice-item">「<em>弾き語り</em>をもっとレベルアップしたい」</div>
                </div>
            </div>
            <!-- 右カラム：フォーム -->
            <div class="reserve-box reveal">
                <h3 style="font-size:1.5rem; margin-bottom:5px;">予約フォーム</h3>
                <p class="form-sub">送信後、24時間以内にご返信します。</p>
                <form id="reserve-form" action="https://formspree.io/f/xykdarno" method="POST">
                    <div class="input-group">
                        <label class="input-label">お名前<span class="required">*</span></label>
                        <input type="text" name="name" class="input-field" placeholder="山田 太郎" required>
                    </div>
                    <div class="input-group">
                        <label class="input-label">メールアドレス<span class="required">*</span></label>
                        <input type="email" name="email" class="input-field" placeholder="your@email.com" required>
                    </div>
                    <div class="input-group">
                        <label class="input-label">電話番号<span class="optional-tag">任意</span></label>
                        <input type="tel" name="phone" class="input-field" placeholder="090-xxxx-xxxx">
                    </div>
                    <div class="input-group">
                        <label class="input-label">興味のある分野</label>
                        <input type="hidden" name="interest" id="interest-hidden" value="">
                        <div class="chip-group">
                            <span class="chip" data-chip>🎵 DTM</span>
                            <span class="chip" data-chip>🎸 楽器</span>
                            <span class="chip" data-chip>🎤 ボーカル</span>
                            <span class="chip" data-chip>🎼 作編曲</span>
                            <span class="chip" data-chip>🤔 未定</span>
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">ご相談内容<span class="optional-tag">任意</span></label>
                        <textarea name="message" class="input-field" rows="3" placeholder="例：この曲みたいな曲を作りたい！/ 機材選びから相談したい / 配信のやり方を知りたい　など"></textarea>
                    </div>
                    <button type="submit" class="submit-btn magnet">予約を確定する</button>
                </form>
                <!-- 送信完了メッセージ -->
                <div id="thank-you" style="display:none; text-align:center; padding:40px 20px;">
                    <div style="font-size:3rem; margin-bottom:15px;">🎉</div>
                    <h3 style="font-size:1.5rem; margin-bottom:10px;">送信ありがとうございます！</h3>
                    <p style="color:#555; line-height:1.8;">24時間以内にご返信いたします。<br>しばらくお待ちください。</p>
                </div>
            </div>
        </div>
        <!-- 下部：ワークフロー（フル幅） -->
        <div class="workflow-area">
            <div class="workflow-label">
                <h3 class="reveal" style="font-family:var(--font-en); font-size:1.8rem; color:var(--c-text); letter-spacing:0.1em;">HOW IT WORKS</h3>
                <p class="reveal" style="color:#888; font-size:0.85rem; margin-top:5px;">送信からレッスン開始まで、こんな流れで進みます。</p>
            </div>
            <div class="workflow-steps">
                <div class="wf-step reveal">
                    <div class="wf-icon"><span>📝</span><span class="wf-num">1</span></div>
                    <div class="wf-content">
                        <div class="wf-step-title">送信</div>
                        <div class="wf-bubble"><div class="wf-speaker">あなた →</div>「<em>DTM始めたい</em>けど、何からやればいいか分からなくて...」</div>
                    </div>
                </div>
                <div class="wf-arrow">▶</div>
                <div class="wf-step reveal">
                    <div class="wf-icon"><span>💌</span><span class="wf-num">2</span></div>
                    <div class="wf-content">
                        <div class="wf-step-title">返信</div>
                        <div class="wf-bubble"><div class="wf-speaker">MASHROOM →</div>「機材ゼロからでも大丈夫！まず<em>30分だけ</em>お話しませんか？」</div>
                    </div>
                </div>
                <div class="wf-arrow">▶</div>
                <div class="wf-step reveal">
                    <div class="wf-icon"><span>📅</span><span class="wf-num">3</span></div>
                    <div class="wf-content">
                        <div class="wf-step-title">日程調整</div>
                        <div class="wf-bubble"><div class="wf-speaker">あなた →</div>「<em>水曜の夜20時</em>なら空いてます！」</div>
                    </div>
                </div>
                <div class="wf-arrow">▶</div>
                <div class="wf-step reveal">
                    <div class="wf-icon"><span>💬</span><span class="wf-num">4</span></div>
                    <div class="wf-content">
                        <div class="wf-step-title">無料相談</div>
                        <div class="wf-bubble"><div class="wf-speaker">MASHROOM →</div>「今ある<em>パソコン、iPhoneだけ</em>でも始められますよ！」</div>
                    </div>
                </div>
                <div class="wf-arrow">▶</div>
                <div class="wf-step wf-step-final reveal">
                    <div class="wf-icon"><span>🎉</span><span class="wf-num">5</span></div>
                    <div class="wf-content">
                        <div class="wf-step-title">スタート！</div>
                        <div class="wf-bubble"><div class="wf-speaker">あなた →</div>「<em>お願いします</em>！」</div>
                        <div class="wf-or">or</div>
                        <div class="wf-bubble wf-bubble-alt"><div class="wf-speaker">あなた →</div>「今回は<em class="em-muted">見送り</em>で！」</div>
                        <div class="wf-ok">どちらでも大丈夫です 🙌</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section style="background: var(--c-bg); padding: 50px 5% 60px; position: relative; z-index: 10; border-top: 5px solid var(--c-text); border-bottom: 5px solid var(--c-text);">
        <div style="max-width: 1400px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; gap: 30px; flex-wrap: wrap;">
            <h2 style="font-family: var(--font-en); font-size: 2.5rem; color: var(--c-text); margin: 0; letter-spacing: 0.1em;">03. LESSON</h2>
            <div style="display: flex; justify-content: center; align-items: center; gap: 20px; flex-wrap: wrap;">
                <a href="/" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">00. HOME</a>
                <a href="/profile" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">01. PROFILE</a>
                <a href="/works" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">02. WORKS</a>
                <a href="/lesson" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white); opacity: 0.5; pointer-events: none;">03. LESSON</a>
                <a href="/gear" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">04. GEAR</a>
                <a href="/price" class="hub-link magnet" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">05. PRICE</a>
                <a href="https://blog.xn--3-sj5c.jp/" class="hub-link magnet" target="_blank" rel="noopener noreferrer" style="font-family: var(--font-en); font-size: 1.2rem; color: var(--c-text); text-decoration: none; padding: 8px 20px; border: 2px solid var(--c-text); border-radius: 30px; transition: 0.3s; background: var(--c-white);">06. BLOG</a>
